---
---

<!-- CONCEPT 1: RESULTS-FIRST PROCESS WITH METRICS -->
<section id="process" class="py-24 bg-stone-100 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">התהליך שלנו</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        תהליך עם תוצאות ברורות
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        כל שלב עם מטרה מדידה. תמיד יודעים איפה אתה ומה התוצאה.
      </p>
    </div>
    
    <div class="relative">
      <!-- Timeline line -->
      <div class="hidden md:block absolute top-0 bottom-0 right-1/2 w-px bg-gradient-to-b from-green-200 via-green-400 to-green-600 dark:from-green-800 dark:via-green-600 dark:to-green-400"></div>
      
      <!-- Steps -->
      <div class="space-y-12 md:space-y-0">
        <!-- Step 1 -->
        <div class="md:grid md:grid-cols-2 md:gap-12 items-center">
          <div class="md:text-left mb-6 md:mb-0">
            <div class="bg-white dark:bg-zinc-950 rounded-3xl p-8 shadow-lg border border-stone-200 dark:border-zinc-800 md:mr-12">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-xl font-bold text-green-700 dark:text-green-400">
                  1
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">שיחת גילוי</h3>
                  <p class="text-sm text-stone-500 dark:text-stone-400">30 דקות</p>
                </div>
              </div>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
                נבין את העסק שלך, נזהה את צווארי הבקבוק, ונמפה איפה אוטומציה תביא את התוצאה הגדולה ביותר.
              </p>
              <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4 border border-green-200 dark:border-green-800">
                <div class="text-center">
                  <div class="text-2xl font-bold text-green-600 dark:text-green-400">תוצאה:</div>
                  <div class="text-sm text-stone-600 dark:text-stone-300">הערכת חיסכון ראשונית</div>
                </div>
              </div>
            </div>
          </div>
          <div class="hidden md:flex justify-start">
            <div class="w-4 h-4 bg-green-400 rounded-full ring-4 ring-white dark:ring-zinc-900"></div>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="md:grid md:grid-cols-2 md:gap-12 items-center md:pt-12">
          <div class="hidden md:flex justify-end order-2 md:order-1">
            <div class="w-4 h-4 bg-green-400 rounded-full ring-4 ring-white dark:ring-zinc-900"></div>
          </div>
          <div class="md:text-right order-1 md:order-2 mb-6 md:mb-0">
            <div class="bg-white dark:bg-zinc-950 rounded-3xl p-8 shadow-lg border border-stone-200 dark:border-zinc-800 md:ml-12">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-xl font-bold text-green-700 dark:text-green-400">
                  2
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">עיצוב הפתרון</h3>
                  <p class="text-sm text-stone-500 dark:text-stone-400">2-3 ימים</p>
                </div>
              </div>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
                בונים את זרימת השיחות, מגדירים את האינטגרציות, ומתכננים את המערכת שתעבוד בדיוק בשבילך.
              </p>
              <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4 border border-green-200 dark:border-green-800">
                <div class="text-center">
                  <div class="text-2xl font-bold text-green-600 dark:text-green-400">תוצאה:</div>
                  <div class="text-sm text-stone-600 dark:text-stone-300">מסמך פתרון מפורט</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="md:grid md:grid-cols-2 md:gap-12 items-center md:pt-12">
          <div class="md:text-left mb-6 md:mb-0">
            <div class="bg-white dark:bg-zinc-950 rounded-3xl p-8 shadow-lg border border-stone-200 dark:border-zinc-800 md:mr-12">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-xl font-bold text-green-700 dark:text-green-400">
                  3
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">בנייה והתקנה</h3>
                  <p class="text-sm text-stone-500 dark:text-stone-400">5-7 ימים</p>
                </div>
              </div>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
                בונים את הצ'אטבוט, מחברים ל-CRM ולוואטסאפ, ומתקינים הכל בעסק שלך. בדיקות מקיפות לפני ההשקה.
              </p>
              <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4 border border-green-200 dark:border-green-800">
                <div class="text-center">
                  <div class="text-2xl font-bold text-green-600 dark:text-green-400">תוצאה:</div>
                  <div class="text-sm text-stone-600 dark:text-stone-300">מערכת פעילה ומוכנה</div>
                </div>
              </div>
            </div>
          </div>
          <div class="hidden md:flex justify-start">
            <div class="w-4 h-4 bg-green-400 rounded-full ring-4 ring-white dark:ring-zinc-900"></div>
          </div>
        </div>
        
        <!-- Step 4 -->
        <div class="md:grid md:grid-cols-2 md:gap-12 items-center md:pt-12">
          <div class="hidden md:flex justify-end order-2 md:order-1">
            <div class="w-4 h-4 bg-green-600 rounded-full ring-4 ring-white dark:ring-zinc-900"></div>
          </div>
          <div class="md:text-right order-1 md:order-2 mb-6 md:mb-0">
            <div class="bg-gradient-to-br from-green-50 to-white dark:from-green-900/20 dark:to-zinc-950 rounded-3xl p-8 shadow-lg border-2 border-green-300 dark:border-green-700 md:ml-12">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-green-500 rounded-xl flex items-center justify-center text-xl font-bold text-white">
                  4
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">השקה ותמיכה</h3>
                  <p class="text-sm text-green-600 dark:text-green-400 font-medium">שבוע ראשון + תמיכה שוטפת</p>
                </div>
              </div>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
                משיקים, מכשירים את הצוות, ומלווים אותך בשבוע הראשון. תמיכה ושדרוגים כלולים לאורך זמן.
              </p>
              <div class="bg-white dark:bg-zinc-900 rounded-xl p-4 border border-green-200 dark:border-green-800">
                <div class="text-center">
                  <div class="text-2xl font-bold text-green-600 dark:text-green-400">תוצאה:</div>
                  <div class="text-sm text-stone-600 dark:text-stone-300">תוצאות מיום ראשון + תמיכה מתמשכת</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Timeline summary -->
    <div class="mt-16 bg-white dark:bg-zinc-950 rounded-3xl p-8 shadow-lg border border-stone-200 dark:border-zinc-800">
      <div class="text-center mb-8">
        <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">מהלך הזמן לתוצאות</h3>
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl font-black text-stone-400 dark:text-stone-500 mb-2">יום 1</div>
          <div class="text-sm text-stone-600 dark:text-stone-300">שיחת גילוי</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-stone-400 dark:text-stone-500 mb-2">יום 7</div>
          <div class="text-sm text-stone-600 dark:text-stone-300">מערכת פעילה</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-green-600 dark:text-green-400 mb-2">יום 14</div>
          <div class="text-sm text-stone-600 dark:text-stone-300">תוצאות ראשונות</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-black text-green-600 dark:text-green-400 mb-2">יום 30</div>
          <div class="text-sm text-stone-600 dark:text-stone-300">ROI מלא</div>
        </div>
      </div>
    </div>
  </div>
</section>
