---
---

<section id="process" class="py-24 bg-gradient-to-br from-slate-50 via-white to-blue-50 dark:from-zinc-950 dark:via-zinc-900 dark:to-slate-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Process Section Header -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-zinc-800 rounded-full mb-6">
        <div class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></div>
        <span class="text-sm font-medium text-slate-600 dark:text-slate-300">התהליך שלנו</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-slate-100 mb-6 tracking-tight">
        תהליך פשוט של 4 שלבים
      </h2>
      <p class="text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
        מפגש ראשון ועד מערכת עובדת תוך שבועות ספורים
      </p>
    </div>
    
    <!-- 4-Step Process with Premium Node Design -->
    <div class="relative">
      <!-- Connection Line -->
      <div class="hidden lg:block absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-r from-slate-200 dark:from-zinc-700 via-blue-500/30 dark:via-blue-400/30 to-slate-200 dark:to-zinc-700 -translate-y-1/2"></div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Step 1 -->
        <div class="group relative scroll-reveal">
          <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg shadow-xl shadow-blue-500/30 z-10 border-4 border-white dark:border-zinc-900">
            1
          </div>
          <div class="bg-white dark:bg-zinc-900/80 backdrop-blur-sm rounded-3xl p-8 border border-slate-200 dark:border-zinc-800 hover:border-blue-500/30 dark:hover:border-blue-400/30 hover:shadow-xl hover:shadow-blue-500/10 transition-all mt-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-br from-blue-500/20 to-blue-600/20 dark:from-blue-500/10 dark:to-blue-600/10 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">גילוי</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-6">
              אנחנו ממפים את הצרכים ומזהים הזדמנויות הגדולות ביותר לאוטומציה
            </p>
            <div class="flex gap-2">
              <span class="px-3 py-1.5 bg-blue-100 dark:bg-blue-900/30 rounded-lg text-xs font-semibold text-blue-700 dark:text-blue-300">אנליזה</span>
              <span class="px-3 py-1.5 bg-blue-100 dark:bg-blue-900/30 rounded-lg text-xs font-semibold text-blue-700 dark:text-blue-300">מיפוי</span>
            </div>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="group relative scroll-reveal delay-100">
          <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-12 h-12 bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg shadow-xl shadow-indigo-500/30 z-10 border-4 border-white dark:border-zinc-900">
            2
          </div>
          <div class="bg-white dark:bg-zinc-900/80 backdrop-blur-sm rounded-3xl p-8 border border-slate-200 dark:border-zinc-800 hover:border-indigo-500/30 dark:hover:border-indigo-400/30 hover:shadow-xl hover:shadow-indigo-500/10 transition-all mt-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-br from-indigo-500/20 to-indigo-600/20 dark:from-indigo-500/10 dark:to-indigo-600/10 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">אסטרטגיה</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-6">
              אנחנו מעצבים זרימות עבודה מותאמות וארכיטקטורת CRM מתקדמת
            </p>
            <div class="flex gap-2">
              <span class="px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg text-xs font-semibold text-indigo-700 dark:text-indigo-300">תכנון</span>
              <span class="px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg text-xs font-semibold text-indigo-700 dark:text-indigo-300">עיצוב</span>
            </div>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="group relative scroll-reveal delay-200">
          <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg shadow-xl shadow-purple-500/30 z-10 border-4 border-white dark:border-zinc-900">
            3
          </div>
          <div class="bg-white dark:bg-zinc-900/80 backdrop-blur-sm rounded-3xl p-8 border border-slate-200 dark:border-zinc-800 hover:border-purple-500/30 dark:hover:border-purple-400/30 hover:shadow-xl hover:shadow-purple-500/10 transition-all mt-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-br from-purple-500/20 to-purple-600/20 dark:from-purple-500/10 dark:to-purple-600/10 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">בנייה ואינטגרציה</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-6">
              אנחנו בונים ומחברים את כל הרכיבים למערכת אוטומטית אמיתית
            </p>
            <div class="flex gap-2">
              <span class="px-3 py-1.5 bg-purple-100 dark:bg-purple-900/30 rounded-lg text-xs font-semibold text-purple-700 dark:text-purple-300">פיתוח</span>
              <span class="px-3 py-1.5 bg-purple-100 dark:bg-purple-900/30 rounded-lg text-xs font-semibold text-purple-700 dark:text-purple-300">אינטגרציה</span>
            </div>
          </div>
        </div>
        
        <!-- Step 4 -->
        <div class="group relative scroll-reveal delay-300">
          <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg shadow-xl shadow-pink-500/30 z-10 border-4 border-white dark:border-zinc-900">
            4
          </div>
          <div class="bg-white dark:bg-zinc-900/80 backdrop-blur-sm rounded-3xl p-8 border border-slate-200 dark:border-zinc-800 hover:border-pink-500/30 dark:hover:border-pink-400/30 hover:shadow-xl hover:shadow-pink-500/10 transition-all mt-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-br from-pink-500/20 to-pink-600/20 dark:from-pink-500/10 dark:to-pink-600/10 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100">העברה ותמיכה</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-6">
              אנחנו מכשירים את הצוות שלכם ומספקים תמיכה מקצועית מתמשכת
            </p>
            <div class="flex gap-2">
              <span class="px-3 py-1.5 bg-pink-100 dark:bg-pink-900/30 rounded-lg text-xs font-semibold text-pink-700 dark:text-pink-300">הדרכה</span>
              <span class="px-3 py-1.5 bg-pink-100 dark:bg-pink-900/30 rounded-lg text-xs font-semibold text-pink-700 dark:text-pink-300">תמיכה</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: scale(0.75) translateY(10px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>
