---
---

<section id="process" class="py-24 bg-stone-100 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider">Our Process</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        Simple 4-Step Process
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        From chaos to automated bliss in weeks, not months
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Step 1 -->
      <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-6 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-stone-100 dark:bg-zinc-900 rounded-xl flex items-center justify-center text-lg font-bold text-stone-700 dark:text-stone-300">
            1
          </div>
          <h3 class="text-lg font-bold text-stone-900 dark:text-stone-100">Discovery</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
          We map your bottlenecks and identify the biggest opportunities for automation
        </p>
      </div>
      
      <!-- Step 2 -->
      <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-6 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-stone-100 dark:bg-zinc-900 rounded-xl flex items-center justify-center text-lg font-bold text-stone-700 dark:text-stone-300">
            2
          </div>
          <h3 class="text-lg font-bold text-stone-900 dark:text-stone-100">Strategy</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
          We design custom bot flows and CRM architecture tailored to your business
        </p>
      </div>
      
      <!-- Step 3 -->
      <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-6 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-stone-100 dark:bg-zinc-900 rounded-xl flex items-center justify-center text-lg font-bold text-stone-700 dark:text-stone-300">
            3
          </div>
          <h3 class="text-lg font-bold text-stone-900 dark:text-stone-100">Build & Integrate</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
          We build and connect all the components to create your automated system
        </p>
      </div>
      
      <!-- Step 4 -->
      <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-6 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-stone-100 dark:bg-zinc-900 rounded-xl flex items-center justify-center text-lg font-bold text-stone-700 dark:text-stone-300">
            4
          </div>
          <h3 class="text-lg font-bold text-stone-900 dark:text-stone-100">Handover & Support</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
          We train your team and provide ongoing support to ensure success
        </p>
      </div>
    </div>
  </div>
</section>
