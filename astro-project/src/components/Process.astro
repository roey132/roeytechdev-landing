<!-- CONCEPT 5: SOCIAL PROOF HEAVY PROCESS -->
<section id="process" class="py-24 bg-white dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-green-600 dark:text-green-400 font-semibold mb-4">התהליך</p>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-4">
        אותו תהליך שעבד עבור 150+ עסקים
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300">בדיוק כמו שעזר להם, הוא יעזור גם לך</p>
    </div>

    <div class="grid md:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl font-bold text-green-600 dark:text-green-400">1</span>
        </div>
        <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-2">גילוי</h3>
        <p class="text-stone-600 dark:text-stone-300 mb-4">נבין את העסק שלך ונמצא איפה אוטומציה תביא את הערך הגדול ביותר</p>
        <p class="text-sm text-green-600 dark:text-green-400 font-medium">⏱️ כ-30 דקות</p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl font-bold text-green-600 dark:text-green-400">2</span>
        </div>
        <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-2">אסטרטגיה</h3>
        <p class="text-stone-600 dark:text-stone-300 mb-4">נתכנן יחד את הפתרון המושלם לצרכים שלך</p>
        <p class="text-sm text-green-600 dark:text-green-400 font-medium">⏱️ 2-3 ימים</p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl font-bold text-green-600 dark:text-green-400">3</span>
        </div>
        <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-2">בנייה</h3>
        <p class="text-stone-600 dark:text-stone-300 mb-4">אנחנו בונים ומתקינים הכל. אתה רק נהנה מהתוצאות</p>
        <p class="text-sm text-green-600 dark:text-green-400 font-medium">⏱️ כשבוע</p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-green-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl font-bold text-white">✓</span>
        </div>
        <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-2">תמיכה</h3>
        <p class="text-stone-600 dark:text-stone-300 mb-4">נשאר איתך לאורך הדרך. כמו שעשינו עם 150+ לקוחות אחרים</p>
        <p class="text-sm text-green-600 dark:text-green-400 font-medium">💚 תמיכה מתמשכת</p>
      </div>
    </div>
  </div>
</section>
