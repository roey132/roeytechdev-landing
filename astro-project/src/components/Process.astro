<!-- CONCEPT 3: MINIMALIST PROCESS -->
<section id="process" class="py-32 bg-white dark:bg-zinc-950">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-24">
      <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-6">התהליך</p>
      <h2 class="text-4xl md:text-5xl font-light text-stone-900 dark:text-stone-100">
        ארבעה שלבים
      </h2>
    </div>
    
    <div class="grid md:grid-cols-4 gap-8 text-center">
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">1</div>
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100">הכירות</h3>
        <p class="text-sm font-light text-stone-500 dark:text-stone-400">נבין את הצרכים</p>
      </div>
      
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">2</div>
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100">תכנון</h3>
        <p class="text-sm font-light text-stone-500 dark:text-stone-400">נבנה פתרון</p>
      </div>
      
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">3</div>
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100">בנייה</h3>
        <p class="text-sm font-light text-stone-500 dark:text-stone-400">נתקין הכל</p>
      </div>
      
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">4</div>
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100">תמיכה</h3>
        <p class="text-sm font-light text-stone-500 dark:text-stone-400">נשאר איתך</p>
      </div>
    </div>
  </div>
</section>
