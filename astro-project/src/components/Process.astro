<section id="process" class="py-20 bg-slate-50 dark:bg-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Simple 4-Step Process
      </h2>
      <p class="text-xl text-slate-600 dark:text-slate-300">
        From chaos to automated bliss in weeks, not months
      </p>
    </div>
    
    <div class="grid md:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="w-20 h-20 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-blue-600 dark:text-blue-400">1</span>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">Discovery</h3>
        <p class="text-slate-600 dark:text-slate-300">
          We map your bottlenecks and identify the biggest opportunities for automation
        </p>
      </div>
      
      <div class="text-center">
        <div class="w-20 h-20 bg-purple-100 dark:bg-purple-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-purple-600 dark:text-purple-400">2</span>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">Strategy</h3>
        <p class="text-slate-600 dark:text-slate-300">
          We design custom bot flows and CRM architecture tailored to your business
        </p>
      </div>
      
      <div class="text-center">
        <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-green-600 dark:text-green-400">3</span>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">Build & Integrate</h3>
        <p class="text-slate-600 dark:text-slate-300">
          We build and connect all the components to create your automated system
        </p>
      </div>
      
      <div class="text-center">
        <div class="w-20 h-20 bg-orange-100 dark:bg-orange-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-orange-600 dark:text-orange-400">4</span>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">Handover & Support</h3>
        <p class="text-slate-600 dark:text-slate-300">
          We train your team and provide ongoing support to ensure success
        </p>
      </div>
    </div>
  </div>
</section>
