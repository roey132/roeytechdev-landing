---
---

<!-- CONCEPT 2: PROBLEM-SOLUTION PROCESS - Journey Together -->
<section id="process" class="py-24 bg-white dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">המסע שלנו יחד</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        נלך איתך בכל שלב
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        לא עוזבים אותך באמצע. מהשיחה הראשונה ועד שאתה מרגיש שיש לך שליטה מלאה.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <!-- Step 1 -->
      <div class="group relative">
        <div class="bg-stone-50 dark:bg-zinc-800 rounded-3xl p-6 h-full border border-stone-100 dark:border-zinc-700 hover:border-green-200 dark:hover:border-green-700 transition-all hover:shadow-lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-white dark:bg-zinc-900 rounded-2xl flex items-center justify-center text-xl font-bold text-green-600 dark:text-green-400 shadow-sm">
              1
            </div>
            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">נכיר</h3>
          </div>
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            שיחת היכרות שבה נבין את העסק שלך, האתגרים, והמטרות. נקשיב, נשאל, ונלמד.
          </p>
          <div class="text-sm text-stone-400 dark:text-stone-500">
            ⏱️ כ-30 דקות
          </div>
        </div>
      </div>
      
      <!-- Step 2 -->
      <div class="group relative">
        <div class="bg-stone-50 dark:bg-zinc-800 rounded-3xl p-6 h-full border border-stone-100 dark:border-zinc-700 hover:border-green-200 dark:hover:border-green-700 transition-all hover:shadow-lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-white dark:bg-zinc-900 rounded-2xl flex items-center justify-center text-xl font-bold text-green-600 dark:text-green-400 shadow-sm">
              2
            </div>
            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">נתכנן</h3>
          </div>
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            נבנה יחד את הפתרון המתאים. נסביר מה אפשרי, מה לא, ומה יביא את הערך הגדול ביותר.
          </p>
          <div class="text-sm text-stone-400 dark:text-stone-500">
            ⏱️ יומיים-שלושה
          </div>
        </div>
      </div>
      
      <!-- Step 3 -->
      <div class="group relative">
        <div class="bg-stone-50 dark:bg-zinc-800 rounded-3xl p-6 h-full border border-stone-100 dark:border-zinc-700 hover:border-green-200 dark:hover:border-green-700 transition-all hover:shadow-lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-white dark:bg-zinc-900 rounded-2xl flex items-center justify-center text-xl font-bold text-green-600 dark:text-green-400 shadow-sm">
              3
            </div>
            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">נבנה</h3>
          </div>
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            אנחנו בונים, מתקינים, ומחברים הכל. אתה לא צריך להבין טכנולוגיה — אנחנו דואגים להכל.
          </p>
          <div class="text-sm text-stone-400 dark:text-stone-500">
            ⏱️ כשבוע
          </div>
        </div>
      </div>
      
      <!-- Step 4 -->
      <div class="group relative">
        <div class="bg-gradient-to-br from-green-50 to-white dark:from-green-900/20 dark:to-zinc-800 rounded-3xl p-6 h-full border-2 border-green-200 dark:border-green-700 hover:shadow-lg transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-green-500 rounded-2xl flex items-center justify-center text-xl font-bold text-white shadow-sm">
              4
            </div>
            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">נלווה</h3>
          </div>
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            מכשירים את הצוות שלך, עונים על שאלות, ונשארים איתך לאורך הדרך. לא לבד.
          </p>
          <div class="text-sm text-green-600 dark:text-green-400 font-medium">
            💚 תמיכה מתמשכת
          </div>
        </div>
      </div>
    </div>
    
    <!-- Promise -->
    <div class="mt-16 max-w-2xl mx-auto text-center">
      <div class="bg-stone-100 dark:bg-zinc-800 rounded-2xl p-6">
        <p class="text-lg text-stone-700 dark:text-stone-200">
          <span class="font-bold">ההבטחה שלנו:</span> אתה לא תצטרך להתמודד עם זה לבד. 
          מהרגע שנתחיל לעבוד יחד, אנחנו שותפים לדרך.
        </p>
      </div>
    </div>
  </div>
</section>
