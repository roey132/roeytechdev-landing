---

<div id="sticky-conversion-bar" class="fixed top-0 left-0 right-0 bg-white dark:bg-zinc-900 border-b-2 border-blue-500 dark:border-blue-600 shadow-lg z-40 transform -translate-y-full transition-transform duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="hidden sm:block w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
          <span class="text-xl">🤖</span>
        </div>
        <div>
          <p class="font-semibold text-stone-900 dark:text-stone-100">
            רוצים לחסוך 20+ שעות בשבוע?
          </p>
          <p class="text-sm text-stone-600 dark:text-stone-400">
            השאירו מספר ונחזור אליכם תוך 5 דקות
          </p>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <input 
          type="tel" 
          placeholder="050-000-0000" 
          class="w-40 px-3 py-2 rounded-lg border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-500 dark:focus:border-blue-600 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
          dir="ltr"
        />
        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition-all whitespace-nowrap">
          דברו איתי 📱
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  let lastScrollY = 0;
  let scrollTimeout;
  
  const stickyBar = document.getElementById('sticky-conversion-bar');
  
  // Show bar after scrolling past hero
  window.addEventListener('scroll', () => {
    const heroSection = document.querySelector('section');
    const heroBottom = heroSection.getBoundingClientRect().bottom;
    
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      if (heroBottom < 100) {
        stickyBar.classList.remove('-translate-y-full');
        stickyBar.classList.add('translate-y-0');
      } else {
        stickyBar.classList.add('-translate-y-full');
        stickyBar.classList.remove('translate-y-0');
      }
    }, 100);
  });
</script>