---
import HeroPhoneDemo from './HeroPhoneDemo.astro';
---

<section class="min-h-screen flex items-center relative overflow-hidden">
  <!-- Static background -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-blue-50 dark:from-zinc-950 dark:via-zinc-900 dark:to-slate-900">
    <!-- Large gradient orbs -->
    <div class="absolute top-[-10%] right-[-5%] w-[700px] h-[700px] bg-gradient-to-br from-blue-600/20 via-blue-500/10 to-transparent rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[600px] h-[600px] bg-gradient-to-tr from-blue-700/15 via-blue-600/10 to-transparent rounded-full blur-3xl"></div>
    <div class="absolute top-[40%] left-[20%] w-[400px] h-[400px] bg-gradient-to-br from-indigo-500/10 to-transparent rounded-full blur-3xl"></div>
    
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    
    <!-- Static geometric shapes -->
    <div class="absolute top-[15%] left-[10%] w-4 h-4 bg-blue-600/30 rotate-45"></div>
    <div class="absolute top-[25%] right-[15%] w-3 h-3 bg-blue-700/40 rotate-45"></div>
    <div class="absolute bottom-[30%] left-[20%] w-2 h-2 bg-indigo-600/30 rotate-45"></div>
    <div class="absolute bottom-[20%] right-[25%] w-3 h-3 bg-blue-800/20 rotate-45"></div>
    
    <!-- Static circles -->
    <div class="absolute top-[20%] left-[8%] w-20 h-20 border-2 border-blue-600/10 rounded-full"></div>
    <div class="absolute top-[60%] right-[10%] w-16 h-16 border-2 border-blue-700/10 rounded-full"></div>
    <div class="absolute bottom-[15%] left-[15%] w-24 h-24 border-2 border-indigo-600/10 rounded-full"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left content - asymmetric -->
      <div class="space-y-8 overflow-visible">
        <div class="overflow-visible">
          <h1 class="text-5xl md:text-7xl font-bold text-stone-900 dark:text-stone-100 leading-tight tracking-tight mb-0">
            חסכו יותר מ-20 שעות בשבוע עם
          </h1>
          <div class="text-5xl md:text-7xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-950 to-blue-800 dark:from-blue-900 dark:to-blue-950 leading-none tracking-tight min-h-[1.1em] flex items-center overflow-visible">
            <span id="typing-text" class="whitespace-nowrap"></span><span id="cursor" class="animate-pulse shrink-0">|</span>
          </div>
        </div>
        
        <p class="text-xl md:text-2xl text-stone-600 dark:text-stone-300 leading-relaxed max-w-xl">
          צ'אטבוט AI מותאם אישית לניהול לידים, מענה מיידי ללקוחות 24/7, וסדר ארגוני חכם שמפנה לכם זמן להתמקד העסק שלכם.
        </p>
        
        <!-- Phone Capture Form - Primary CTA -->
        <div class="bg-white dark:bg-zinc-900 rounded-2xl p-6 border-2 border-blue-900/20 dark:border-blue-800/30 shadow-xl">
          <p class="text-lg font-semibold text-stone-900 dark:text-stone-100 mb-4">
            השאירו פרטים ונחזור אליכם בהקדם!
          </p>
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <input 
                type="text"
                placeholder="שם פרטי" 
                class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
              />
              <input 
                type="text"
                placeholder="שם משפחה" 
                class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
              />
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
              <input 
                type="tel"
                placeholder="050-000-0000" 
                class="flex-1 px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
                dir="ltr"
              />
              <button class="px-6 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-xl font-semibold transition-all transform hover:scale-105 whitespace-nowrap">
                דברו איתי
              </button>
            </div>
          </div>
          <p class="text-xs text-stone-500 dark:text-stone-400 mt-3">
           ללא התחייבות • שיחת ייעוץ בחינם
          </p>
        </div>
        
        <!-- Secondary CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a href="https://wa.me/972500000000?text=היי,%20אני%20רוצה%20לשמוע%20על%20אוטומציה" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-full font-semibold transition-all transform hover:scale-105">
            💬 שלחו הודעה בוואטסאפ
          </a>
          <a href="#process" class="inline-flex items-center justify-center px-6 py-3 bg-transparent border-2 border-blue-900/30 dark:border-blue-700 text-blue-900 dark:text-blue-300 rounded-full font-semibold hover:bg-blue-50 dark:hover:bg-blue-900/10 transition-all">
            למדו עוד על התהליך
          </a>
        </div>
      </div>
      
      <!-- Right content - Modern phone demo -->
      <div class="relative">
        <HeroPhoneDemo />
        
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-full h-full bg-blue-900/10 dark:bg-blue-900/20 rounded-3xl -z-10"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const phrases = [
    'צאטבוט AI',
    'זמינות 24/7',
    'סדר ארגוני',
    'עובד שלא נח',
    'מוח דיגיטלי'
  ];
  
  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typingSpeed = 100;
  
  const typingElement = document.getElementById('typing-text');
  
  function type() {
    const currentPhrase = phrases[phraseIndex];
    
    if (isDeleting) {
      typingElement.textContent = currentPhrase.substring(0, charIndex - 1);
      charIndex--;
      typingSpeed = 30;
    } else {
      typingElement.textContent = currentPhrase.substring(0, charIndex + 1);
      charIndex++;
      typingSpeed = 100;
    }
    
    if (!isDeleting && charIndex === currentPhrase.length) {
      isDeleting = true;
      typingSpeed = 2000; // Pause at end
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      phraseIndex = (phraseIndex + 1) % phrases.length;
      typingSpeed = 500; // Pause before typing new phrase
    }
    
    setTimeout(type, typingSpeed);
  }
  
  // Start the animation
  setTimeout(type, 1000);
</script>
