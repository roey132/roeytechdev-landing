---
import HeroPhoneDemo from './HeroPhoneDemo.astro';
---

<section class="min-h-screen flex items-center relative overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-20 left-10 w-72 h-72 bg-blue-900/20 dark:bg-blue-950/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-800/20 dark:bg-blue-900/30 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left content - asymmetric -->
      <div class="space-y-8">
        <div class="inline-block">
        </div>
        
        <h1 class="text-5xl md:text-7xl font-bold text-stone-900 dark:text-stone-100 leading-tight tracking-tight">
          חסון יותר מ-20 שעות בשבוע עם
          <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-blue-900 to-blue-700 dark:from-blue-700 dark:to-blue-900">
            אוטומציית AI
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-stone-600 dark:text-stone-300 leading-relaxed max-w-xl">
          צ'אטבוט AI מותאם אישית ומערכת CRM אוטומטית שלוכדים לידים, מגיבים ללקוחות 24/7 ומבטלים משימות חוזרות
        </p>
        
        <!-- Phone Capture Form - Primary CTA -->
        <div class="bg-white dark:bg-zinc-900 rounded-2xl p-6 border-2 border-blue-900/20 dark:border-blue-800/30 shadow-xl">
          <div class="flex items-center gap-2 mb-3">
            <div class="flex items-center gap-1">
              <div class="w-2 h-2 bg-blue-900 rounded-full animate-pulse"></div>
              <span class="text-sm font-semibold text-blue-900 dark:text-blue-300">
                50+ עסקים כבר חוסכים 20+ שעות בשבוע
              </span>
            </div>
          </div>
          <p class="text-lg font-semibold text-stone-900 dark:text-stone-100 mb-4">
            השאירו מספר ונחזור אליכם בהקדם!
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <input 
              type="tel"
              placeholder="050-000-0000" 
              class="flex-1 px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
              dir="ltr"
            />
            <button class="px-6 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-xl font-semibold transition-all transform hover:scale-105 whitespace-nowrap">
              דברו איתי
            </button>
          </div>
          <p class="text-xs text-stone-500 dark:text-stone-400 mt-3">
           ללא התחייבות • שיחה ייעוצית חינמית
          </p>
        </div>
        
        <!-- Secondary CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a href="https://wa.me/972500000000?text=היי,%20אני%20רוצה%20לשמוע%20על%20אוטומציה" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-full font-semibold transition-all transform hover:scale-105">
            💬 שלחו הודעה בוואטסאפ
          </a>
          <a href="#process" class="inline-flex items-center justify-center px-6 py-3 bg-transparent border-2 border-blue-900/30 dark:border-blue-700 text-blue-900 dark:text-blue-300 rounded-full font-semibold hover:bg-blue-50 dark:hover:bg-blue-900/10 transition-all">
            למדו עוד על התהליך
          </a>
        </div>
      </div>
      
      <!-- Right content - Modern phone demo -->
      <div class="relative">
        <HeroPhoneDemo />
        
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-full h-full bg-blue-900/10 dark:bg-blue-900/20 rounded-3xl -z-10"></div>
      </div>
    </div>
  </div>
</section>
