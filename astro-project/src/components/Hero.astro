---
import WhatsAppDemo from './WhatsAppDemo.astro';
---

<section class="min-h-screen flex items-center relative overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-20 left-10 w-72 h-72 bg-green-200 dark:bg-green-900/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-green-300 dark:bg-green-800/30 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left content - asymmetric -->
      <div class="space-y-8">
        <div class="inline-block">
          <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">אוטומציה AI</span>
        </div>
        
        <h1 class="text-5xl md:text-7xl font-bold text-stone-900 dark:text-stone-100 leading-tight tracking-tight">
          חסון יותר מ-20 שעות בשבוע עם
          <span class="block mt-2 text-transparent bg-clip-text bg-linear-to-r from-green-600 to-green-400 dark:from-green-400 dark:to-green-600">
            אוטומציית AI
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-stone-600 dark:text-stone-300 leading-relaxed max-w-xl">
          צ'אטבוט AI מותאם אישית ומערכת CRM אוטומטית שלוכדים לידים, מגיבים ללקוחות 24/7 ומבטלים משימות חוזרות
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-green-600 hover:bg-green-700 text-white rounded-full font-semibold text-lg transition-all transform hover:scale-105">
            קבע פגישה חינמית
          </a>
          <a href="#demo" class="inline-flex items-center justify-center px-8 py-4 bg-transparent border-2 border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 rounded-full font-semibold text-lg hover:bg-green-50 dark:hover:bg-green-900/20 transition-all">
            נסה הדגמה חיה
          </a>
        </div>
      </div>
      
      <!-- Right content - WhatsApp demo -->
      <div class="relative">
        <WhatsAppDemo />
        
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-full h-full bg-green-100 dark:bg-green-900/30 rounded-3xl -z-10"></div>
      </div>
    </div>
  </div>
</section>
