---

<!-- CONCEPT 3: MINIMALIST PREMIUM HERO -->
<section class="min-h-screen flex items-center justify-center bg-white dark:bg-zinc-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center space-y-12">
      
      <!-- Single powerful word -->
      <h1 class="text-7xl md:text-9xl lg:text-[12rem] font-extralight text-stone-900 dark:text-stone-100 tracking-tight leading-none">
        זמן
      </h1>
      
      <!-- Subtle statement -->
      <p class="text-2xl md:text-3xl font-light text-stone-400 dark:text-stone-500 tracking-wide">
        הוא הנכס היקר ביותר שלך
      </p>
      
      <!-- Single line -->
      <p class="text-xl md:text-2xl font-light text-stone-600 dark:text-stone-300 max-w-lg mx-auto">
        אנחנו מחזירים לך אותו
      </p>
      
      <!-- Minimal CTA -->
      <div class="pt-12">
        <a href="#contact" class="group inline-flex items-center gap-4 text-lg font-light text-stone-900 dark:text-stone-100 hover:text-green-600 dark:hover:text-green-400 transition-colors">
          <span>בואו נדבר</span>
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
  
  <!-- Subtle scroll indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2">
    <div class="w-px h-20 bg-gradient-to-b from-transparent via-stone-200 dark:via-zinc-700 to-transparent"></div>
  </div>
</section>

<!-- What We Do - Minimal -->
<section id="services" class="py-32 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-24">
      <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-6">מה אנחנו עושים</p>
      <h2 class="text-4xl md:text-5xl font-light text-stone-900 dark:text-stone-100">
        אוטומציה שמשחררת אותך
      </h2>
    </div>
    
    <div class="grid md:grid-cols-3 gap-16 md:gap-8 text-center">
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">01</div>
        <p class="text-stone-600 dark:text-stone-300 font-light">
          צ'אטבוט שמבין את הלקוחות שלך
        </p>
      </div>
      
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">02</div>
        <p class="text-stone-600 dark:text-stone-300 font-light">
          CRM שעובד לבד
        </p>
      </div>
      
      <div class="space-y-4">
        <div class="text-5xl font-extralight text-green-600 dark:text-green-400">03</div>
        <p class="text-stone-600 dark:text-stone-300 font-light">
          לידים שמגיעים מוכנים
        </p>
      </div>
    </div>
  </div>
</section>

<!-- The Result - Minimal -->
<section class="py-32 bg-white dark:bg-zinc-950">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-8">התוצאה</p>
    
    <div class="mb-4">
      <span class="text-7xl md:text-9xl font-extralight text-stone-900 dark:text-stone-100">25+</span>
    </div>
    
    <p class="text-2xl font-light text-stone-400 dark:text-stone-500 mb-8">
      שעות בשבוע
    </p>
    
    <p class="text-xl font-light text-stone-500 dark:text-stone-400 max-w-md mx-auto">
      שחוזרות אליך
    </p>
  </div>
</section>
