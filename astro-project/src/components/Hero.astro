---

<!-- CONCEPT 3: MINIMALIST PREMIUM HERO -->
<section class="min-h-screen flex items-center justify-center relative bg-white dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center space-y-12">
      <!-- Single powerful statement -->
      <div class="space-y-8">
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-extralight text-stone-900 dark:text-stone-100 tracking-tight leading-none">
          זמן
        </h1>
        <h2 class="text-3xl md:text-4xl font-light text-stone-400 dark:text-stone-500 tracking-wide">
          הוא הנכס היקר ביותר שלך
        </h2>
      </div>

      <!-- Single line description -->
      <p class="text-xl md:text-2xl text-stone-600 dark:text-stone-300 font-light max-w-2xl mx-auto">
        אנחנו מחזירים לך אותו
      </p>

      <!-- Minimal CTA -->
      <div class="pt-8">
        <a href="#contact" class="group inline-flex items-center gap-4 text-lg font-medium text-stone-900 dark:text-stone-100 hover:text-green-600 dark:hover:text-green-400 transition-colors">
          <span>בואו נדבר</span>
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Subtle scroll indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2">
    <div class="w-px h-16 bg-gradient-to-b from-transparent via-stone-300 dark:via-zinc-600 to-transparent"></div>
  </div>
</section>

<!-- The What - Minimal -->
<section class="py-32 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-24 items-center">
      <div class="space-y-8">
        <p class="text-sm font-medium text-green-600 dark:text-green-400 tracking-widest uppercase">מה אנחנו עושים</p>
        <h2 class="text-4xl md:text-5xl font-light text-stone-900 dark:text-stone-100 leading-tight">
          אוטומציה שמשחררת אותך
        </h2>
        <p class="text-xl text-stone-600 dark:text-stone-300 font-light leading-relaxed">
          צ'אטבוט חכם. CRM שעובד לבד. לידים שמגיעים מוכנים.
        </p>
      </div>

      <div class="space-y-6">
        <div class="flex items-center gap-6 py-6 border-b border-stone-200 dark:border-zinc-700">
          <span class="text-3xl font-extralight text-green-600 dark:text-green-400">01</span>
          <span class="text-lg text-stone-700 dark:text-stone-200">כל ליד מטופל מיידית</span>
        </div>
        <div class="flex items-center gap-6 py-6 border-b border-stone-200 dark:border-zinc-700">
          <span class="text-3xl font-extralight text-green-600 dark:text-green-400">02</span>
          <span class="text-lg text-stone-700 dark:text-stone-200">80% מהשאלות נענות אוטומטית</span>
        </div>
        <div class="flex items-center gap-6 py-6">
          <span class="text-3xl font-extralight text-green-600 dark:text-green-400">03</span>
          <span class="text-lg text-stone-700 dark:text-stone-200">אתה מקבל רק מה שחשוב</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- The Result - Minimal -->
<section class="py-32 bg-white dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-sm font-medium text-green-600 dark:text-green-400 tracking-widest uppercase mb-8">התוצאה</p>
    <h2 class="text-6xl md:text-8xl font-extralight text-stone-900 dark:text-stone-100 mb-4">
      25+
    </h2>
    <p class="text-2xl text-stone-500 dark:text-stone-400 font-light">
      שעות בשבוע
    </p>
    <p class="text-xl text-stone-400 dark:text-stone-500 font-light mt-8 max-w-md mx-auto">
      שחוזרות אליך. לדברים שבאמת חשובים.
    </p>
  </div>
</section>
