<!-- CONCEPT 2: PROBLEM-SOLUTION CTA - Gentle Invitation -->
<section id="contact" class="py-24 bg-gradient-to-b from-stone-50 to-green-50/30 dark:from-zinc-900 dark:to-green-950/10">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    
    <p class="text-stone-500 dark:text-stone-400 mb-4">בואו נדבר</p>
    <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
      ספר לנו מה אתה מרגיש
    </h2>
    <p class="text-xl text-stone-600 dark:text-stone-300 mb-12 max-w-2xl mx-auto">
      שיחה אחת, בלי התחייבות. נבין את המצב שלך, נשאל את השאלות הנכונות, 
      ונראה אם ואיך אנחנו יכולים לעזור.
    </p>

    <!-- Conversation invitation cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white dark:bg-zinc-900 rounded-2xl p-6 shadow-lg border border-stone-100 dark:border-zinc-800 hover:shadow-xl transition-shadow">
        <div class="text-4xl mb-4">☕</div>
        <h3 class="font-bold text-stone-900 dark:text-stone-100 mb-2">שיחה פתוחה</h3>
        <p class="text-sm text-stone-500 dark:text-stone-400">30 דקות של הקשבה. נבין את האתגרים שלך.</p>
      </div>
      
      <div class="bg-white dark:bg-zinc-900 rounded-2xl p-6 shadow-lg border border-stone-100 dark:border-zinc-800 hover:shadow-xl transition-shadow">
        <div class="text-4xl mb-4">🤝</div>
        <h3 class="font-bold text-stone-900 dark:text-stone-100 mb-2">בלי לחץ</h3>
        <p class="text-sm text-stone-500 dark:text-stone-400">לא ננסה למכור לך. רק נראה אם זה מתאים.</p>
      </div>
      
      <div class="bg-white dark:bg-zinc-900 rounded-2xl p-6 shadow-lg border border-stone-100 dark:border-zinc-800 hover:shadow-xl transition-shadow">
        <div class="text-4xl mb-4">💡</div>
        <h3 class="font-bold text-stone-900 dark:text-stone-100 mb-2">תקבל כיוון</h3>
        <p class="text-sm text-stone-500 dark:text-stone-400">גם אם לא נעבוד יחד, תצא עם תובנות.</p>
      </div>
    </div>

    <!-- What to expect -->
    <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-12 shadow-xl border border-stone-100 dark:border-zinc-800 mb-12 max-w-2xl mx-auto">
      <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-6">מה קורה בשיחה?</h3>
      
      <div class="space-y-4 text-right">
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
            <span class="text-green-600 dark:text-green-400 font-bold text-sm">1</span>
          </div>
          <p class="text-stone-600 dark:text-stone-300">
            <strong class="text-stone-800 dark:text-stone-100">נכיר אותך</strong> — נבין את העסק שלך, האתגרים, והמטרות.
          </p>
        </div>
        
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
            <span class="text-green-600 dark:text-green-400 font-bold text-sm">2</span>
          </div>
          <p class="text-stone-600 dark:text-stone-300">
            <strong class="text-stone-800 dark:text-stone-100">נזהה הזדמנויות</strong> — נראה איפה אוטומציה יכולה לעזור, ואיפה לא.
          </p>
        </div>
        
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
            <span class="text-green-600 dark:text-green-400 font-bold text-sm">3</span>
          </div>
          <p class="text-stone-600 dark:text-stone-300">
            <strong class="text-stone-800 dark:text-stone-100">נציע כיוון</strong> — אם זה מתאים, נסביר איך נוכל לעזור. אם לא — נהיה כנים.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
      <a href="https://wa.me/972501234567" target="_blank" class="inline-flex items-center justify-center gap-3 px-10 py-5 bg-green-600 hover:bg-green-700 text-white rounded-full font-bold text-xl transition-all transform hover:scale-105 shadow-lg shadow-green-600/20">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        בוא נדבר בוואטסאפ
      </a>
    </div>

    <!-- Alternative -->
    <p class="text-stone-400 dark:text-stone-500 text-sm">
      או שלחו מייל ל- <a href="mailto:contact@roeytechdev.com" class="text-green-600 dark:text-green-400 hover:underline">contact@roeytechdev.com</a>
    </p>
    
    <!-- Reassurance -->
    <p class="text-stone-400 dark:text-stone-500 text-xs mt-8 max-w-md mx-auto">
      💚 אנחנו מאמינים בשקיפות. אם לא נוכל לעזור, נגיד את זה. אם נוכל — נסביר בדיוק איך.
    </p>
  </div>
</section>
