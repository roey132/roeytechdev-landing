<section id="contact" class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
      Ready to Stop Wasting Time on Repetitive Tasks?
    </h2>
    <p class="text-xl text-stone-600 dark:text-stone-300 mb-12 max-w-2xl mx-auto">
      Book a free 30-minute consultation to see how automation can transform your business
    </p>
    
    <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-12 border border-stone-200 dark:border-zinc-800 mb-10">
      <div class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider mb-6">Select a time that works for you</div>
      <div class="grid grid-cols-3 gap-4 max-w-md mx-auto">
        <button class="bg-stone-100 dark:bg-zinc-950 border-2 border-stone-200 dark:border-zinc-800 rounded-2xl p-5 hover:border-stone-400 dark:hover:border-zinc-700 transition-all group">
          <div class="font-bold text-stone-900 dark:text-stone-100 group-hover:scale-105 transition-transform">Mon</div>
          <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Mar 31</div>
        </button>
        <button class="bg-stone-100 dark:bg-zinc-950 border-2 border-stone-200 dark:border-zinc-800 rounded-2xl p-5 hover:border-stone-400 dark:hover:border-zinc-700 transition-all group">
          <div class="font-bold text-stone-900 dark:text-stone-100 group-hover:scale-105 transition-transform">Tue</div>
          <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Apr 1</div>
        </button>
        <button class="bg-stone-100 dark:bg-zinc-950 border-2 border-stone-200 dark:border-zinc-800 rounded-2xl p-5 hover:border-stone-400 dark:hover:border-zinc-700 transition-all group">
          <div class="font-bold text-stone-900 dark:text-stone-100 group-hover:scale-105 transition-transform">Wed</div>
          <div class="text-sm text-stone-500 dark:text-stone-400 mt-1">Apr 2</div>
        </button>
      </div>
    </div>
    
    <a href="mailto:contact@roeytechdev.com" class="inline-flex items-center justify-center px-10 py-5 bg-green-600 hover:bg-green-700 text-white rounded-full font-semibold text-lg transition-all transform hover:scale-105">
      Book Your Free Consultation
    </a>
  </div>
</section>
