---
---

<section id="contact" class="py-24 bg-gradient-to-br from-blue-50 to-stone-50 dark:from-blue-900/20 dark:to-zinc-900/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Urgency Banner -->
    <div class="inline-flex items-center gap-2 bg-red-100 dark:bg-red-900/30 rounded-full px-6 py-2 mb-8 scroll-reveal">
      <div class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></div>
      <span class="text-red-700 dark:text-red-400 font-semibold text-sm">
        רק 3 מקומות פנויים לחודש הבא
      </span>
    </div>
    
    <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
      מוכן להפסיק לבזבז זמן על משימות חוזרות?
    </h2>
    <p class="text-xl text-stone-600 dark:text-stone-300 mb-12 max-w-2xl mx-auto">
      קבעו פגישת ייעוץ חינמית של 30 דקות כדי לראות איך אוטומציה יכולה לשנות את העסק שלכם
    </p>
    
    <!-- Primary Phone Capture Form -->
    <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-12 border-2 border-blue-900/20 dark:border-blue-800/30 shadow-xl mb-8 scroll-reveal delay-100">
      <div class="flex items-center justify-center gap-2 mb-6">
        <div class="w-3 h-3 bg-blue-900 rounded-full animate-pulse"></div>
        <span class="text-blue-900 dark:text-blue-300 font-semibold">
          תגובה מיידית • תוך 5 דקות
        </span>
      </div>
      
      <div class="space-y-3 max-w-lg mx-auto mb-4">
        <div class="grid grid-cols-2 gap-3">
          <input 
            type="text" 
            placeholder="שם פרטי" 
            class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
          />
          <input 
            type="text" 
            placeholder="שם משפחה" 
            class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
          />
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <input 
            type="tel" 
            placeholder="050-000-0000" 
            class="flex-1 px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
            dir="ltr"
          />
          <button class="px-6 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-xl font-semibold transition-all transform hover:scale-105 whitespace-nowrap">
            קבעו ייעוץ חינמי 📱
          </button>
        </div>
      </div>
      
      <div class="flex items-center justify-center gap-6 text-sm">
        <span class="text-stone-600 dark:text-stone-400">🔒 ללא התחייבות</span>
        <span class="text-stone-400">|</span>
        <span class="text-stone-600 dark:text-stone-400">✓ שביעות רצון מובטחת</span>
        <span class="text-stone-400">|</span>
        <span class="text-stone-600 dark:text-stone-400">⚡ תוצאות תוך 30 יום</span>
      </div>
    </div>
    
    <!-- Secondary Contact Options -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center scroll-reveal delay-200">
      <a href="https://wa.me/972500000000?text=היי,%20אני%20רוצה%20לקבוע%20ייעוץ%20חינמי" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-blue-900 hover:bg-blue-800 text-white rounded-full font-semibold transition-all transform hover:scale-105">
        <span>💬</span>
        <span>שלחו הודעה בוואטסאפ</span>
      </a>
      <a href="mailto:contact@roeytechdev.com" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-transparent border-2 border-stone-300 dark:border-zinc-700 text-stone-700 dark:text-stone-300 rounded-full font-semibold hover:bg-stone-50 dark:hover:bg-zinc-900 transition-all">
        <span>✉️</span>
        <span>שלחו אימייל</span>
      </a>
    </div>
    
    <!-- Trust Badges -->
    <div class="mt-12 flex items-center justify-center gap-8 flex-wrap scroll-reveal delay-300">
      <div class="flex items-center gap-2 text-stone-600 dark:text-stone-400">
        <span class="text-2xl">🔒</span>
        <span class="text-sm">מאובטח ופרטי</span>
      </div>
      <div class="flex items-center gap-2 text-stone-600 dark:text-stone-400">
        <span class="text-2xl">✓</span>
        <span class="text-sm">התחייבות ל-100% שביעות רצון</span>
      </div>
      <div class="flex items-center gap-2 text-stone-600 dark:text-stone-400">
        <span class="text-2xl">⚡</span>
        <span class="text-sm">תוצאות תוך 30 יום</span>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: scale(0.8) translateY(12px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>
