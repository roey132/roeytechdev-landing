---
---

<!-- CONCEPT 1: INTERACTIVE ROI CALCULATOR -->
<section id="roi-calculator" class="py-24 bg-gradient-to-br from-stone-900 to-stone-800 dark:from-zinc-950 dark:to-zinc-900 text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-green-400 font-semibold mb-4 uppercase tracking-wider">מחשבון החיסכון שלך</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        כמה תחסוך?
      </h2>
      <p class="text-xl text-stone-300 max-w-2xl mx-auto">
        הכנס את הפרטים שלך וקבל הערכה מיידית של החיסכון הפוטנציאלי
      </p>
    </div>

    <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-12 shadow-2xl">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Input Side -->
        <div class="space-y-8">
          <div>
            <label class="block text-stone-700 dark:text-stone-200 font-semibold mb-3">
              כמה פניות לקוחות אתה מקבל ביום?
            </label>
            <input 
              type="range" 
              id="daily-leads" 
              min="5" 
              max="100" 
              value="20" 
              class="w-full h-3 bg-stone-200 dark:bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-green-600"
            />
            <div class="flex justify-between text-sm text-stone-500 dark:text-stone-400 mt-2">
              <span>5</span>
              <span id="daily-leads-value" class="text-2xl font-bold text-green-600 dark:text-green-400">20</span>
              <span>100</span>
            </div>
          </div>

          <div>
            <label class="block text-stone-700 dark:text-stone-200 font-semibold mb-3">
              כמה זמן ממוצע לוקח לענות על פנייה (דקות)?
            </label>
            <input 
              type="range" 
              id="response-time" 
              min="2" 
              max="30" 
              value="10" 
              class="w-full h-3 bg-stone-200 dark:bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-green-600"
            />
            <div class="flex justify-between text-sm text-stone-500 dark:text-stone-400 mt-2">
              <span>2</span>
              <span id="response-time-value" class="text-2xl font-bold text-green-600 dark:text-green-400">10</span>
              <span>30</span>
            </div>
          </div>

          <div>
            <label class="block text-stone-700 dark:text-stone-200 font-semibold mb-3">
              כמה שעות בשבוע מתבזבזות על תשובות חוזרות?
            </label>
            <input 
              type="range" 
              id="wasted-hours" 
              min="2" 
              max="40" 
              value="15" 
              class="w-full h-3 bg-stone-200 dark:bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-green-600"
            />
            <div class="flex justify-between text-sm text-stone-500 dark:text-stone-400 mt-2">
              <span>2</span>
              <span id="wasted-hours-value" class="text-2xl font-bold text-green-600 dark:text-green-400">15</span>
              <span>40</span>
            </div>
          </div>

          <div>
            <label class="block text-stone-700 dark:text-stone-200 font-semibold mb-3">
              ערך ממוצע של לקוח (₪)?
            </label>
            <input 
              type="range" 
              id="customer-value" 
              min="100" 
              max="10000" 
              value="1000" 
              step="100"
              class="w-full h-3 bg-stone-200 dark:bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-green-600"
            />
            <div class="flex justify-between text-sm text-stone-500 dark:text-stone-400 mt-2">
              <span>₪100</span>
              <span id="customer-value-value" class="text-2xl font-bold text-green-600 dark:text-green-400">₪1,000</span>
              <span>₪10,000</span>
            </div>
          </div>
        </div>

        <!-- Results Side -->
        <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-2xl p-8 border border-green-200 dark:border-green-800">
          <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-8 text-center">
            החיסכון הפוטנציאלי שלך
          </h3>

          <div class="space-y-6">
            <!-- Time Saved -->
            <div class="bg-white dark:bg-zinc-900 rounded-xl p-6 text-center shadow-lg">
              <div class="text-5xl font-black text-green-600 dark:text-green-400 mb-2" id="hours-saved">20</div>
              <div class="text-stone-600 dark:text-stone-300 font-medium">שעות בשבוע תחזור אליך</div>
              <div class="text-sm text-stone-400 dark:text-stone-500 mt-2">זמן שיכול ללכת למכירות, לא למענה</div>
            </div>

            <!-- Leads Saved -->
            <div class="bg-white dark:bg-zinc-900 rounded-xl p-6 text-center shadow-lg">
              <div class="text-5xl font-black text-green-600 dark:text-green-400 mb-2" id="leads-saved">15</div>
              <div class="text-stone-600 dark:text-stone-300 font-medium">לידים שלא ילכו לאיבוד בחודש</div>
              <div class="text-sm text-stone-400 dark:text-stone-500 mt-2">78% מהלקוחות עוזבים אחרי 5 דקות בלי מענה</div>
            </div>

            <!-- Monthly Value -->
            <div class="bg-white dark:bg-zinc-900 rounded-xl p-6 text-center shadow-lg border-2 border-green-300 dark:border-green-700">
              <div class="text-4xl font-black text-green-600 dark:text-green-400 mb-2">
                ₪<span id="monthly-value">15,000</span>
              </div>
              <div class="text-stone-600 dark:text-stone-300 font-medium">ערך חודשי פוטנציאלי</div>
              <div class="text-sm text-stone-400 dark:text-stone-500 mt-2">לידים שנשמרו × ערך לקוח</div>
            </div>
          </div>

          <!-- CTA -->
          <div class="mt-8 text-center">
            <a href="#contact" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-600 hover:bg-green-700 text-white rounded-full font-bold text-lg transition-all transform hover:scale-105 w-full">
              רוצה להשיג את זה?
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-center text-stone-400 dark:text-stone-500 text-sm mt-8">
      * ההערכות מבוססות על נתוני לקוחות קיימים. התוצאות בפועל עשויות להשתנות.
    </p>
  </div>
</section>

<script>
  // ROI Calculator Logic
  const dailyLeadsSlider = document.getElementById('daily-leads');
  const responseTimeSlider = document.getElementById('response-time');
  const wastedHoursSlider = document.getElementById('wasted-hours');
  const customerValueSlider = document.getElementById('customer-value');

  const dailyLeadsValue = document.getElementById('daily-leads-value');
  const responseTimeValue = document.getElementById('response-time-value');
  const wastedHoursValue = document.getElementById('wasted-hours-value');
  const customerValueValue = document.getElementById('customer-value-value');

  const hoursSavedEl = document.getElementById('hours-saved');
  const leadsSavedEl = document.getElementById('leads-saved');
  const monthlyValueEl = document.getElementById('monthly-value');

  function calculateROI() {
    const dailyLeads = parseInt(dailyLeadsSlider.value);
    const wastedHours = parseInt(wastedHoursSlider.value);
    const customerValue = parseInt(customerValueSlider.value);

    // Calculate hours saved (assuming 80% automation)
    const hoursSaved = Math.round(wastedHours * 0.8);

    // Calculate leads saved (78% leave without answer, we save 50% of those)
    const leadsLostMonthly = Math.round(dailyLeads * 30 * 0.78);
    const leadsSaved = Math.round(leadsLostMonthly * 0.5);

    // Calculate monthly value
    const monthlyValue = leadsSaved * customerValue;

    // Update display
    hoursSavedEl.textContent = hoursSaved;
    leadsSavedEl.textContent = leadsSaved;
    monthlyValueEl.textContent = monthlyValue.toLocaleString('he-IL');

    // Update slider value displays
    dailyLeadsValue.textContent = dailyLeads;
    responseTimeValue.textContent = responseTimeSlider.value;
    wastedHoursValue.textContent = wastedHours;
    customerValueValue.textContent = '₪' + customerValue.toLocaleString('he-IL');
  }

  // Add event listeners
  dailyLeadsSlider.addEventListener('input', calculateROI);
  responseTimeSlider.addEventListener('input', calculateROI);
  wastedHoursSlider.addEventListener('input', calculateROI);
  customerValueSlider.addEventListener('input', calculateROI);

  // Initial calculation
  calculateROI();
</script>
