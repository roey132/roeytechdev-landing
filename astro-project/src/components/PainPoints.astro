---
import MessageCard from './MessageCard.astro';
---

<section class="py-24 bg-stone-100 dark:bg-zinc-900 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Top left accent -->
    <div class="absolute top-0 left-0 w-64 h-64 bg-gradient-to-br from-red-100/30 to-transparent dark:from-red-900/20 rounded-bl-3xl"></div>
    
    <!-- Bottom right accent -->
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-gradient-to-tl from-blue-100/30 to-transparent dark:from-blue-900/20 rounded-tl-3xl"></div>
    
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    
    <!-- Floating circles -->
    <div class="absolute top-20 right-20 w-2 h-2 bg-red-400/20 rounded-full"></div>
    <div class="absolute top-40 right-40 w-3 h-3 bg-red-400/15 rounded-full"></div>
    <div class="absolute bottom-32 left-32 w-2 h-2 bg-blue-400/20 rounded-full"></div>
    <div class="absolute bottom-48 left-48 w-4 h-4 bg-blue-400/10 rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left - Title area -->
      <div class="lg:sticky lg:top-32">
        <div class="inline-block mb-4 scroll-reveal">
          <span class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider">הבעיה</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight flex items-center gap-3 whitespace-nowrap">
          מכיר את התחושה?
          <!-- Notification bell icon -->
          <span class="inline-flex items-center justify-center w-12 h-12 bg-red-500 rounded-full text-white shadow-lg notify-v4 relative">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2zm-2 1H8v-6c0-2.48 1.51-4.5 4-4.5s4 2.02 4 4.5v6z"/>
            </svg>
            <span class="absolute inset-0 rounded-full bg-red-500 ring-v4"></span>
          </span>
        </h2>
        <p class="text-xl text-stone-600 dark:text-stone-300 leading-relaxed scroll-reveal delay-200">
          בעיות אלו עולות לעסקים אלפים בהכנסות כל חודש - והן בדיוק מה שצ'אטבוט AI פותר
        </p>
      </div>
      
      <!-- Right - Pain points as conversation -->
      <div class="space-y-8" dir="rtl">
        
        <!-- Pain Point 1: Customer Complaint -->
        <div class="space-y-4">
          <!-- Customer message (problem) -->
          <div class="flex justify-start scroll-reveal">
            <MessageCard color="red" direction="left" size="lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">😤</span>
                <span class="font-bold">שאלות חוזרות</span>
              </div>
              <p class="text-sm">שוב פעם הוא שאל אותי על זמינות ומחיר.. נמאס לי לענות על אותו דבר</p>
            </MessageCard>
          </div>
          
          <!-- Bot message (solution) -->
          <div class="flex justify-end scroll-reveal delay-100">
            <MessageCard color="blue" direction="right" size="lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">✅</span>
                <span class="font-bold">הפתרון שלנו</span>
              </div>
              <p class="text-sm">הצ'אטבוט שלנו עונה מיידית - 24/7! לקוחות מקבלים תשובה תוך שניות בלי שאתה צריך לפתוח את הטלפון.</p>
            </MessageCard>
          </div>
        </div>

        <!-- Pain Point 2: Repetitive Questions -->
        <div class="space-y-4">
          <!-- Customer message (problem) -->
          <div class="flex justify-start scroll-reveal delay-200">
            <MessageCard color="red" direction="left" size="lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">😫</span>
                <span class="font-bold">"סגרתי עם מישהו אחר"</span>
              </div>
              <p class="text-sm">חזרתי ללקוח אחרי חצי שעה והוא כבר סגר עם מישהו אחר..</p>
            </MessageCard>
          </div>
          
          <!-- Bot message (solution) -->
          <div class="flex justify-end scroll-reveal delay-300">
            <MessageCard color="blue" direction="right" size="lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">🤖</span>
                <span class="font-bold">הפתרון שלנו</span>
              </div>
              <p class="text-sm">הצ'אטבוט עונה בשנייה שהלקוח שלח הודעה. הוא 'נועל' אותו אצלך בעסק כשהוא עוד חם ומוכן לקנות.</p>
            </MessageCard>
          </div>
        </div>

        <!-- Pain Point 3: Lost Leads -->
        <div class="space-y-4">
          <!-- Customer message (problem) -->
          <div class="flex justify-start scroll-reveal delay-400">
            <MessageCard color="red" direction="left" size="lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">😢</span>
                <span class="font-bold">לידים שאבדו</span>
              </div>
              <p class="text-sm">הלקוח שלח לי הודעה ושכחתי לחזור אליו.. עכשיו הוא כבר לא עונה לי</p>
            </MessageCard>
          </div>
          
          <!-- Bot message (solution) -->
          <div class="flex justify-end scroll-reveal delay-500">
            <MessageCard color="blue" direction="right" size="lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">💰</span>
                <span class="font-bold">הפתרון שלנו</span>
              </div>
              <p class="text-sm">הצ'אטבוט זמין 24/7, גם בשעות שבת וחג, שומר הכל ומתעד את השיחה. לידים חמים לא נעלמים לעולם!</p>
            </MessageCard>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .pain-point-conversation {
    transition: all 0.3s ease;
  }

  .pain-point-conversation:hover {
    transform: translateY(-4px);
  }

  /* Disable MessageCard's built-in animation for pain points */
  .pain-point-conversation :global(.message-card) {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }

  /* Enable scroll animation for individual messages */
  .scroll-reveal {
    opacity: 0;
    transform: scale(0.7) translateY(10px);
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* Add subtle glow effect on hover */
  .pain-point-conversation:hover :global(.message-card),
  .scroll-reveal:hover :global(.message-card) {
    box-shadow: 0 8px 30px -10px rgba(59, 130, 246, 0.3) !important;
  }

  /* Make problem messages (now blue) stand out */
  .pain-point-conversation :global(.bg-blue-600),
  .scroll-reveal :global(.bg-blue-600) {
    box-shadow: 0 4px 20px -5px rgba(59, 130, 246, 0.4) !important;
  }

  /* Make solution messages (now red) stand out */
  .pain-point-conversation :global(.bg-red-600),
  .scroll-reveal :global(.bg-red-600) {
    box-shadow: 0 4px 20px -5px rgba(239, 68, 68, 0.3) !important;
  }

  /* Notification bell animation - Only ring animates, bell stays still */
  .ring-v4 {
    animation: ring 1s ease-out infinite;
    animation-delay: 0.5s;
  }

  @keyframes ring {
    0% { opacity: 0; transform: scale(1); }
    20% { opacity: 0.3; transform: scale(1.2); }
    100% { opacity: 0; transform: scale(2.5); }
  }
</style>
