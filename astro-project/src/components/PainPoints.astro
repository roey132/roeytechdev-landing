<!-- CONCEPT 3: MINIMALIST PAIN POINTS -->
<section class="py-32 bg-white dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-24">
      <p class="text-sm font-medium text-green-600 dark:text-green-400 tracking-widest uppercase mb-6">הבעיה</p>
      <h2 class="text-4xl md:text-5xl font-light text-stone-900 dark:text-stone-100">
        הזמן שלך נגמר
      </h2>
    </div>

    <!-- Minimal pain cards -->
    <div class="grid md:grid-cols-3 gap-16 max-w-5xl mx-auto">
      <div class="text-center space-y-6">
        <div class="text-6xl font-extralight text-stone-200 dark:text-zinc-700">78%</div>
        <p class="text-lg text-stone-600 dark:text-stone-300 font-light">
          מהלקוחות עוזבים אחרי 5 דקות בלי תשובה
        </p>
      </div>

      <div class="text-center space-y-6">
        <div class="text-6xl font-extralight text-stone-200 dark:text-zinc-700">15ש"ש</div>
        <p class="text-lg text-stone-600 dark:text-stone-300 font-light">
          מתבזבזות בשבוע על שאלות חוזרות
        </p>
      </div>

      <div class="text-center space-y-6">
        <div class="text-6xl font-extralight text-stone-200 dark:text-zinc-700">0</div>
        <p class="text-lg text-stone-600 dark:text-stone-300 font-light">
          פניות שמקבלות מענה בלילה
        </p>
      </div>
    </div>

    <!-- Single line solution -->
    <div class="max-w-2xl mx-auto text-center mt-24">
      <p class="text-2xl text-stone-900 dark:text-stone-100 font-light">
        יש פתרון
      </p>
    </div>
  </div>
</section>
