---
---

<section class="py-24 bg-stone-100 dark:bg-zinc-900 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left - Title area -->
      <div class="lg:sticky lg:top-32">
        <div class="inline-block mb-4">
          <span class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider">הבעיה</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
          מכיר?
        </h2>
        <p class="text-xl text-stone-600 dark:text-stone-300 leading-relaxed">
          בעיות אלו עולות לעסקים אלפים בהכנסות כל חודש
        </p>
      </div>
      
      <!-- Right - Pain points with different layout -->
      <div class="space-y-6">
        <!-- Pain Point 1 -->
        <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-8 border border-green-200 dark:border-green-900/50 hover:border-green-300 dark:hover:border-green-800 transition-all">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-2xl">
              ⏰
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-3">
                זמן תגובה איטי
              </h3>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
                מאבדים לידים כי לא מצליחים להגיב לפניות ברשתות החברתיות מספיק מהר. כל דקה עולה לך לקוחות פוטנציאליים.
              </p>
            </div>
          </div>
        </div>
        
        <!-- Pain Point 2 -->
        <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-8 border border-green-200 dark:border-green-900/50 hover:border-green-300 dark:hover:border-green-800 transition-all">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-2xl">
              📊
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-3">
                הזנת נתונים ידנית
              </h3>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
                מבזבזים שעות כל יום בהעתקת מידע מאימייל והודעות לגוליות. זה מייגע ומועד לטעויות.
              </p>
            </div>
          </div>
        </div>
        
        <!-- Pain Point 3 -->
        <div class="group relative bg-white dark:bg-zinc-950 rounded-2xl p-8 border border-green-200 dark:border-green-900/50 hover:border-green-300 dark:hover:border-green-800 transition-all">
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-2xl">
              🔄
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-3">
                תהליכי מעקב חלשים
              </h3>
              <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
                מעקב לקוחות לא מאורגן גורם לכך ששוכחים לחזור. לידים מתקררים והזדמנויות מחמיצות דרך החריצים.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
