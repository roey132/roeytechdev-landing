---
---
<div class="relative w-[320px] mx-auto" id="whatsapp-demo">
  <!-- Phone Frame -->
  <div class="relative bg-stone-900 dark:bg-zinc-900 rounded-[3rem] p-2 shadow-2xl">
    <!-- Dynamic Island -->
    <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-32 h-7 bg-black rounded-b-2xl z-10"></div>
    
    <!-- Inner Screen -->
    <div class="bg-stone-100 dark:bg-zinc-950 rounded-[2.5rem] overflow-hidden flex flex-col h-[640px]">
      <!-- Status Bar -->
      <div class="bg-green-600 dark:bg-green-700 px-6 pt-8 pb-2 flex justify-between items-center flex-shrink-0">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          <span class="text-white text-xs font-medium">WhatsApp Business</span>
        </div>
        <div class="text-white text-[10px]">🔔 3</div>
      </div>

      <!-- Chat Header -->
      <div class="bg-green-600 dark:bg-green-700 px-4 py-3 flex items-center gap-3 flex-shrink-0">
        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-white font-semibold text-sm truncate">RoeyTechDev Bot</div>
          <div class="text-green-100 text-[10px] flex items-center gap-1">
            <span class="w-1.5 h-1.5 bg-green-300 rounded-full animate-pulse"></span>
            מחובר
          </div>
        </div>
      </div>

      <!-- Messages Container -->
      <div class="flex-1 overflow-y-auto overflow-x-hidden px-3 py-3 space-y-2" id="chat-messages">
        <!-- Messages will be inserted here -->
      </div>

      <!-- Typing Indicators -->
      <div id="typing-indicator-bot" class="px-3 pb-2 hidden">
        <div class="inline-flex items-center gap-1 bg-white dark:bg-zinc-800 rounded-2xl rounded-bl-sm px-3 py-1.5 shadow-sm">
          <div class="flex gap-0.5">
            <div class="w-1.5 h-1.5 bg-stone-400 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
            <div class="w-1.5 h-1.5 bg-stone-400 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
            <div class="w-1.5 h-1.5 bg-stone-400 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
          </div>
        </div>
      </div>
      
      <div id="typing-indicator-customer" class="px-3 pb-2 hidden justify-end">
        <div class="inline-flex items-center gap-1 bg-green-600 rounded-2xl rounded-br-sm px-3 py-1.5 shadow-sm">
          <div class="flex gap-0.5">
            <div class="w-1.5 h-1.5 bg-white rounded-full animate-bounce" style="animation-delay: 0ms"></div>
            <div class="w-1.5 h-1.5 bg-white rounded-full animate-bounce" style="animation-delay: 150ms"></div>
            <div class="w-1.5 h-1.5 bg-white rounded-full animate-bounce" style="animation-delay: 300ms"></div>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="bg-stone-100 dark:bg-zinc-950 border-t border-stone-200 dark:border-zinc-800 flex-shrink-0">
        <!-- iPhone Home Indicator -->
        <div class="flex justify-center items-center py-4">
          <div class="w-32 h-1 bg-stone-400 dark:bg-zinc-600 rounded-full"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #whatsapp-demo {
    transition: all 0.3s ease;
  }

  #chat-messages {
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
  }

  #chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  #chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  #chat-messages::-webkit-scrollbar-thumb {
    background: #d6d3d1;
    border-radius: 2px;
  }

  #chat-messages::-webkit-scrollbar-thumb:hover {
    background: #a8a29e;
  }

  @keyframes messageSlideIn {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.8);
    }
    60% {
      transform: translateY(-5px) scale(1.02);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .message-animation {
    animation: messageSlideIn 0.4s ease-out forwards;
  }

  .typing-dot {
    animation: typingBounce 1.4s infinite ease-in-out both;
  }

  .typing-dot:nth-child(1) {
    animation-delay: -0.32s;
  }

  .typing-dot:nth-child(2) {
    animation-delay: -0.16s;
  }

  @keyframes typingBounce {
    0%, 80%, 100% {
      transform: scale(0);
    }
    40% {
      transform: scale(1);
    }
  }
</style>

<script>
  const messages = [
    { type: 'customer', text: 'היי, אני מתעניין בשירותי האוטומציה שלכם' },
    { type: 'bot', text: 'היי! 👋 ברור הבא ל-RoeyTechDev. איך אני יכול לעזור לך היום?' },
    { type: 'customer', text: 'אני בעל עסק קטן ואני רוצה להוסיף צ\'אטבוט לאתר שלי' },
    { type: 'bot', text: 'מצוין! 😊 צ\'אטבוט באתר יכול לעזור לך ללכוד לידים 24/7, גם כשאתה סגור. כמה פניות אתה מקבל בחודש בערך?' },
    { type: 'customer', text: 'בערך 50-100 פניות, תלוי בעונה' },
    { type: 'bot', text: 'בולו! אז צ\'אטבוט יכול לחסוך לך המון זמן. הוא יכול לענות על שאלות נפוצות, לסנן לידים ולהעביר לך רק פניות רלוונטיות. תרצה לשמוע עוד?' },
    { type: 'customer', text: 'כן, בהחלט! זה נשמע בדיוק מה שאני צריך' },
    { type: 'bot', text: '👍 אשמח להסביר לך יותר! בוא נשב פגישה קצרה של 15 דקות ואני אראה לך איך זה עובד בדיוק. מתי מתאים לך?' },
  ];

  let currentMessageIndex = 0;
  const chatMessages = document.getElementById('chat-messages');
  const typingIndicatorBot = document.getElementById('typing-indicator-bot');
  const typingIndicatorCustomer = document.getElementById('typing-indicator-customer');

  function createMessageElement(message) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `flex ${message.type === 'customer' ? 'justify-end' : 'justify-start'}`;

    const bubbleClass = message.type === 'customer'
      ? 'bg-green-600 text-white rounded-2xl rounded-br-sm'
      : 'bg-white dark:bg-zinc-800 text-stone-900 dark:text-stone-100 rounded-2xl rounded-bl-sm';

    messageDiv.innerHTML = `
      <div class="max-w-[85%] ${bubbleClass} px-3 py-1.5 shadow-sm">
        <p class="text-xs leading-relaxed">${message.text}</p>
        <div class="text-[8px] mt-0.5 ${message.type === 'customer' ? 'text-green-100' : 'text-stone-400 dark:text-zinc-500'} flex items-center justify-end gap-0.5">
          <span>${new Date().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' })}</span>
          ${message.type === 'customer' ? '<svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>' : ''}
        </div>
      </div>
    `;

    return messageDiv;
  }

  function showTyping(type) {
    if (type === 'bot') {
      typingIndicatorBot.classList.remove('hidden');
    } else {
      typingIndicatorCustomer.classList.remove('hidden');
      typingIndicatorCustomer.classList.add('flex');
    }
  }

  function hideTyping(type) {
    if (type === 'bot') {
      typingIndicatorBot.classList.add('hidden');
    } else {
      typingIndicatorCustomer.classList.add('hidden');
      typingIndicatorCustomer.classList.remove('flex');
    }
  }

  function addMessage(message) {
    const messageElement = createMessageElement(message);
    
    // Start with hidden state
    messageElement.style.opacity = '0';
    
    chatMessages.appendChild(messageElement);
    
    // Trigger animation after a brief delay
    setTimeout(() => {
      messageElement.style.opacity = '1';
      messageElement.classList.add('message-animation');
      
      // Scroll to show the new message
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }, 50);
  }

  async function playConversation() {
    if (currentMessageIndex >= messages.length) {
      // Reset and restart
      await new Promise(resolve => setTimeout(resolve, 3000));
      chatMessages.innerHTML = '';
      currentMessageIndex = 0;
    }

    const message = messages[currentMessageIndex];

    // Show typing indicator first
    showTyping(message.type);
    await new Promise(resolve => setTimeout(resolve, 800));
    hideTyping(message.type);

    addMessage(message);
    currentMessageIndex++;

    // Schedule next message with faster timing
    const nextDelay = message.type === 'bot' ? 1800 : 1500;
    setTimeout(playConversation, nextDelay);
  }

  // Start the conversation when the component loads
  setTimeout(playConversation, 1000);
</script>
