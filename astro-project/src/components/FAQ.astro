<!-- CONCEPT 5: SOCIAL PROOF HEAVY FAQ -->
<section class="py-24 bg-white dark:bg-zinc-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-green-600 dark:text-green-400 font-semibold mb-4">שאלות נפוצות</p>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100">
        השאלות ש-150+ לקוחות שאלו לפניך
      </h2>
    </div>

    <div class="space-y-4">
      <div class="bg-stone-50 dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-100 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">כמה זמן לוקח לראות תוצאות?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed">87% מהלקוחות שלנו רואים תוצאות תוך שבוע ראשון. המערכת מתחילה לעבוד מיום אחד, והשיפור המשמעותי מגיע תוך 30 יום.</p>
        </div>
      </div>

      <div class="bg-stone-50 dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-100 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">מה ה-ROI הממוצע?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed">הלקוחות שלנו מדווחים על החזר השקעה של פי 3-5 תוך 60 יום. רוב העסקים מחזירים את ההשקעה כבר בחודש הראשון.</p>
        </div>
      </div>

      <div class="bg-stone-50 dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-100 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">לאילו עסקים זה מתאים?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed">עבדנו עם 150+ עסקים: נדל"ן, איקומרס, שירותים מקצועיים, תיירות, בריאות ויופי, ועוד. כל עסק שמקבל פניות מלקוחות יכול להרוויח.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function toggleFAQ(button) {
    const answer = button.nextElementSibling;
    const icon = button.querySelector('svg');
    answer.classList.toggle('hidden');
    icon.classList.toggle('rotate-180');
  }
</script>
