<!-- CONCEPT 3: MINIMALIST FAQ -->
<section class="py-32 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20">
      <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-6">שאלות</p>
      <h2 class="text-4xl md:text-5xl font-light text-stone-900 dark:text-stone-100">
        תשובות
      </h2>
    </div>
    
    <div class="space-y-8">
      <div class="border-b border-stone-200 dark:border-zinc-700 pb-6">
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100 mb-2">כמה זמן לוקח לראות תוצאות?</h3>
        <p class="font-light text-stone-500 dark:text-stone-400">שבוע. המערכת מתחילה לעבוד מיום אחד.</p>
      </div>
      
      <div class="border-b border-stone-200 dark:border-zinc-700 pb-6">
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100 mb-2">צריך להבין טכנולוגיה?</h3>
        <p class="font-light text-stone-500 dark:text-stone-400">לא. אנחנו דואגים להכל.</p>
      </div>
      
      <div class="border-b border-stone-200 dark:border-zinc-700 pb-6">
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100 mb-2">לאילו עסקים זה מתאים?</h3>
        <p class="font-light text-stone-500 dark:text-stone-400">כל עסק שמקבל פניות מלקוחות.</p>
      </div>
      
      <div class="pb-6">
        <h3 class="text-lg font-light text-stone-900 dark:text-stone-100 mb-2">מה המחיר?</h3>
        <p class="font-light text-stone-500 dark:text-stone-400">תלוי בפרויקט. נדבר ונבין.</p>
      </div>
    </div>
  </div>
</section>
