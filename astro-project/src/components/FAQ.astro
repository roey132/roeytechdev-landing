---
---

<!-- CONCEPT 1: RESULTS-FIRST FAQ -->
<section class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">שאלות על תוצאות</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        שאלות שמעניינות אותך
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300">
        תשובות מבוססות נתונים, לא הבטחות ריקות
      </p>
    </div>
    
    <div class="space-y-4">
      <!-- FAQ Item 1 - ROI focused -->
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">כמה זמן לוקח לראות תוצאות?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            <span class="text-green-600 dark:text-green-400 font-bold">רוב הלקוחות רואים תוצאות תוך 7 ימים.</span> המערכת מתחילה לעבוד מהרגע שהיא מותקנת - לידים מתקבלים, שאלות נענות, והזמן שלך מתפנה.
          </p>
          <div class="bg-stone-100 dark:bg-zinc-800 rounded-xl p-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold text-green-600 dark:text-green-400">יום 1</div>
                <div class="text-xs text-stone-500 dark:text-stone-400">התקנה</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-green-600 dark:text-green-400">יום 7</div>
                <div class="text-xs text-stone-500 dark:text-stone-400">תוצאות ראשונות</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-green-600 dark:text-green-400">יום 30</div>
                <div class="text-xs text-stone-500 dark:text-stone-400">ROI מלא</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- FAQ Item 2 - Metrics -->
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">מה ה-ROI הממוצע?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            לקוחות שלנו מדווחים על <span class="text-green-600 dark:text-green-400 font-bold">החזר השקעה של פי 3-5 תוך 60 יום</span>. החיסכון מגיע משלושה מקורות:
          </p>
          <ul class="space-y-2 text-stone-600 dark:text-stone-300">
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-1">✓</span>
              <span><strong>זמן:</strong> 20-30 שעות בשבוע חוזרות לעסק</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-1">✓</span>
              <span><strong>לידים:</strong> 30-50% יותר לידים שמומרים</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-500 mt-1">✓</span>
              <span><strong>כוח אדם:</strong> אין צורך בעובד נוסף למענה</span>
            </li>
          </ul>
        </div>
      </div>
      
      <!-- FAQ Item 3 - Pricing -->
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">כמה זה עולה?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            המחיר תלוי בהיקף הפרויקט, אבל רוב הלקוחות מתחילים עם השקעה של <span class="text-green-600 dark:text-green-400 font-bold">₪3,500 - ₪15,000</span> להקמה, ותשלום חודשי קטן לתחזוקה.
          </p>
          <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4 border border-green-200 dark:border-green-800">
            <p class="text-sm text-green-700 dark:text-green-300">
              💡 <strong>עובדה:</strong> עובד במשרה מלאה למענה טלפוני עולה ₪8,000-12,000 לחודש. המערכת שלנו עובדת 24/7 בחלק קטן מהמחיר.
            </p>
          </div>
        </div>
      </div>
      
      <!-- FAQ Item 4 - Measurement -->
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">איך מודדים הצלחה?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            אנחנו מספקים דשבורד עם מדדים ברורים שמתעדכנים בזמן אמת:
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-stone-100 dark:bg-zinc-800 rounded-xl p-4 text-center">
              <div class="text-xl font-bold text-stone-900 dark:text-stone-100">לידים שנלכדו</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">כמה פניות התקבלו</div>
            </div>
            <div class="bg-stone-100 dark:bg-zinc-800 rounded-xl p-4 text-center">
              <div class="text-xl font-bold text-stone-900 dark:text-stone-100">זמן תגובה</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">ממוצע בשניות</div>
            </div>
            <div class="bg-stone-100 dark:bg-zinc-800 rounded-xl p-4 text-center">
              <div class="text-xl font-bold text-stone-900 dark:text-stone-100">שיחות שנחסכו</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">כמה טיפל הבוט</div>
            </div>
            <div class="bg-stone-100 dark:bg-zinc-800 rounded-xl p-4 text-center">
              <div class="text-xl font-bold text-stone-900 dark:text-stone-100">שביעות רצון</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">דירוג לקוחות</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- FAQ Item 5 - Industries -->
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">לאילו עסקים זה מתאים?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            כל עסק שמקבל פניות מלקוחות יכול להרוויח. הלקוחות שלנו מגיעים מ:
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">נדל"ן</span>
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">איקומרס</span>
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">שירותים מקצועיים</span>
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">תיירות ואירוח</span>
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">בריאות ויופי</span>
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">חינוך</span>
            <span class="px-3 py-1 bg-stone-100 dark:bg-zinc-800 rounded-full text-sm text-stone-600 dark:text-stone-300">מסעדנות</span>
          </div>
        </div>
      </div>
      
      <!-- FAQ Item 6 - Getting started -->
      <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-stone-200 dark:border-zinc-800 overflow-hidden">
        <button class="w-full px-6 py-5 flex items-center justify-between text-right hover:bg-stone-50 dark:hover:bg-zinc-800 transition-colors cursor-pointer" onclick="toggleFAQ(this)">
          <span class="text-lg font-semibold text-stone-900 dark:text-stone-100 pr-4">איך מתחילים?</span>
          <svg class="w-6 h-6 text-green-600 dark:text-green-400 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="px-6 pb-6 hidden">
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed mb-4">
            שיחת היכרות אחת של 30 דקות. בלי התחייבות, בלי לחץ. נבין את הצרכים שלך ונראה אם ואיך אפשר לעזור.
          </p>
          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-xl font-semibold transition-all">
            קבע שיחת היכרות
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function toggleFAQ(button) {
    const answer = button.nextElementSibling;
    const icon = button.querySelector('svg');
    
    // Toggle the answer visibility
    answer.classList.toggle('hidden');
    
    // Rotate the icon
    icon.classList.toggle('rotate-180');
  }
</script>
