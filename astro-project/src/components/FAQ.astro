---
import MessageCard from './MessageCard.astro';
---

<section class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">שאלות נפוצות</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        שאלות ששואלות לעיתים
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300">
        לחצו על השאלות כדי לראות את התשובות
      </p>
    </div>
    
    <!-- Bubble Stack Container -->
    <div class="max-w-2xl mx-auto" dir="rtl">
      <div class="space-y-6">
        
        <!-- FAQ Bubble 1 -->
        <div class="faq-bubble-item scroll-reveal">
          <!-- Question Bubble -->
          <div class="flex justify-center mb-4">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-full px-8 py-4 shadow-lg hover:shadow-xl transition-all cursor-pointer question-bubble transform hover:scale-105">
              <p class="font-bold text-lg">איזה AI אתם משתמשים בצ'אטבוט?</p>
            </div>
          </div>
          
          <!-- Answer Bubble -->
          <div class="flex justify-center">
            <div class="answer-bubble opacity-100 max-w-lg">
              <MessageCard color="blue" direction="left" size="lg">
                <p class="font-medium mb-2">הצ'אטבוט שלנו משתמש ב-OpenAI GPT-4 מתקדם, שמותאם אישית לעסק שלך.</p>
                <p class="text-sm opacity-90">הוא לומד את השפה, הטון והמידע הספציפי שלך, ומחובר למערכת CRM שלך.</p>
              </MessageCard>
            </div>
          </div>
        </div>

        <!-- FAQ Bubble 2 -->
        <div class="faq-bubble-item scroll-reveal delay-100">
          <!-- Question Bubble -->
          <div class="flex justify-center mb-4">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-full px-8 py-4 shadow-lg hover:shadow-xl transition-all cursor-pointer question-bubble transform hover:scale-105">
              <p class="font-bold text-lg">כמה זמן לוקח להקים את המערכת?</p>
            </div>
          </div>
          
          <!-- Answer Bubble -->
          <div class="flex justify-center">
            <div class="answer-bubble opacity-0 max-w-lg">
              <MessageCard color="blue" direction="left" size="lg">
                <p class="font-medium mb-2">התהליך המלא אורך בין שבוע לשבועיים, תלוי במורכבות הפרויקט.</p>
                <p class="text-sm opacity-90">ביום הראשון נבנה את הגרסה הראשונית, ואז נעבור יחד על התאמות.</p>
              </MessageCard>
            </div>
          </div>
        </div>

        <!-- FAQ Bubble 3 -->
        <div class="faq-bubble-item scroll-reveal delay-200">
          <!-- Question Bubble -->
          <div class="flex justify-center mb-4">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-full px-8 py-4 shadow-lg hover:shadow-xl transition-all cursor-pointer question-bubble transform hover:scale-105">
              <p class="font-bold text-lg">האם הצ'אטבוט יכול לסגור מכירות?</p>
            </div>
          </div>
          
          <!-- Answer Bubble -->
          <div class="flex justify-center">
            <div class="answer-bubble opacity-0 max-w-lg">
              <MessageCard color="blue" direction="left" size="lg">
                <p class="font-medium mb-2">בהחלט! הצ'אטבוט יכול לענות על שאלות נפוצות, לקבוע תורים, ולסגור מכירות פשוטות.</p>
                <p class="text-sm opacity-90">הוא יעביר אליך רק פניות שמצריכות התערבות אנושית.</p>
              </MessageCard>
            </div>
          </div>
        </div>

        <!-- FAQ Bubble 4 -->
        <div class="faq-bubble-item scroll-reveal delay-300">
          <!-- Question Bubble -->
          <div class="flex justify-center mb-4">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-full px-8 py-4 shadow-lg hover:shadow-xl transition-all cursor-pointer question-bubble transform hover:scale-105">
              <p class="font-bold text-lg">כמה עולה להקים מערכת כזו?</p>
            </div>
          </div>
          
          <!-- Answer Bubble -->
          <div class="flex justify-center">
            <div class="answer-bubble opacity-0 max-w-lg">
              <MessageCard color="blue" direction="left" size="lg">
                <p class="font-medium mb-2">ההשקעה ההתחלתית מתחילה מ-5,000₪, אבל הרוב הלקוחות מקבלים החזר השקעה תוך חודש-חודשיים.</p>
                <p class="text-sm opacity-90">אנחנו מציעים גם תשלומים, ותמיד נעשה לך הדגמה חינמית לפני שמתחילים.</p>
              </MessageCard>
            </div>
          </div>
        </div>

        <!-- FAQ Bubble 5 -->
        <div class="faq-bubble-item scroll-reveal delay-400">
          <!-- Question Bubble -->
          <div class="flex justify-center mb-4">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-full px-8 py-4 shadow-lg hover:shadow-xl transition-all cursor-pointer question-bubble transform hover:scale-105">
              <p class="font-bold text-lg">מה קורה אם הצ'אטבוט לא יודע לענות?</p>
            </div>
          </div>
          
          <!-- Answer Bubble -->
          <div class="flex justify-center">
            <div class="answer-bubble opacity-0 max-w-lg">
              <MessageCard color="blue" direction="left" size="lg">
                <p class="font-medium mb-2">הצ'אטבוט מסוגל לענות על 80-90% מהפניות אוטומטית, כולל בשעות שבת וחג.</p>
                <p class="text-sm opacity-90">כשהוא לא בטוח, הוא מעביר את השיחה לך או לצוות שלך מיידית.</p>
              </MessageCard>
            </div>
          </div>
        </div>

        <!-- FAQ Bubble 6 -->
        <div class="faq-bubble-item scroll-reveal delay-500">
          <!-- Question Bubble -->
          <div class="flex justify-center mb-4">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-full px-8 py-4 shadow-lg hover:shadow-xl transition-all cursor-pointer question-bubble transform hover:scale-105">
              <p class="font-bold text-lg">איך אני מתחיל ומה קורה אחרי?</p>
            </div>
          </div>
          
          <!-- Answer Bubble -->
          <div class="flex justify-center">
            <div class="answer-bubble opacity-0 max-w-lg">
              <MessageCard color="blue" direction="left" size="lg">
                <p class="font-medium mb-2">אנחנו מספקים הדרכה מלאה לך ולצוות שלך, כולל מדריך שימוש ותמיכה טכנית 24/7.</p>
                <p class="text-sm opacity-90">בנוסף, אנחנו זמינים לשיחות וואטסאפ וטלפוניות לכל שאלה או בעיה.</p>
              </MessageCard>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .answer-bubble {
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateY(20px) scale(0.8);
    pointer-events: none;
  }

  .answer-bubble.opacity-100 {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
    pointer-events: all;
  }

  .question-bubble {
    transition: all 0.3s ease;
  }

  .question-bubble:hover {
    box-shadow: 0 20px 40px -10px rgba(59, 130, 246, 0.3) !important;
  }

  /* Active question state */
  .question-bubble.active {
    transform: scale(0.95);
    box-shadow: 0 10px 30px -5px rgba(59, 130, 246, 0.2) !important;
  }

  /* Add connecting line between Q&A */
  .faq-bubble-item {
    position: relative;
  }

  .faq-bubble-item::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 0;
    background: linear-gradient(to bottom, #3b82f6, #60a5fa);
    transition: height 0.3s ease;
    opacity: 0.3;
    z-index: 0;
  }

  .faq-bubble-item:hover::after {
    height: 40px;
  }

  /* Disable MessageCard's built-in animation */
  .answer-bubble :global(.message-card) {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }

  /* Enable scroll animation for FAQ items */
  .faq-bubble-item.scroll-reveal {
    opacity: 0;
    transform: scale(0.8) translateY(15px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .faq-bubble-item.scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const questionBubbles = document.querySelectorAll('.question-bubble');
    
    // First answer is visible by default, first question is active
    if (questionBubbles.length > 0) {
      questionBubbles[0].classList.add('active');
    }
    
    questionBubbles.forEach((bubble, index) => {
      bubble.addEventListener('click', () => {
        const faqItem = bubble.closest('.faq-bubble-item');
        const answer = faqItem.querySelector('.answer-bubble');
        const isOpen = answer.classList.contains('opacity-100');
        
        // Close all other answers
        questionBubbles.forEach((otherBubble, i) => {
          if (i !== index) {
            const otherItem = otherBubble.closest('.faq-bubble-item');
            const otherAnswer = otherItem.querySelector('.answer-bubble');
            otherAnswer.classList.remove('opacity-100');
            otherBubble.classList.remove('active');
          }
        });
        
        // Toggle current
        if (isOpen) {
          answer.classList.remove('opacity-100');
          bubble.classList.remove('active');
        } else {
          answer.classList.add('opacity-100');
          bubble.classList.add('active');
        }
      });
    });
  });
</script>
