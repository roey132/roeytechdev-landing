---
---

<section class="py-16 bg-gradient-to-br from-blue-50 to-stone-50 dark:from-blue-900/20 dark:to-zinc-900/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div id="conversion-form-container" class="bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-12 shadow-xl border border-blue-900/20 dark:border-blue-800/30 scroll-reveal">
      <div class="flex items-center justify-center gap-2 mb-4">
        <div class="w-3 h-3 bg-blue-900 rounded-full animate-pulse"></div>
        <span class="text-sm font-semibold text-blue-900 dark:text-blue-300">
          זמין עכשיו • תגובה מיידית
        </span>
      </div>
      
      <h2 class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100 mb-4">
        מוכנים לפתור את הבעיות האלו?
      </h2>
      
      <p class="text-xl text-stone-600 dark:text-stone-300 mb-8 max-w-2xl mx-auto">
        דברו איתנו כדי להתחיל לעשות סדר בעסק שלכם.
      </p>
      
      <div class="space-y-3 max-w-lg mx-auto mb-4">
        <div class="grid grid-cols-2 gap-3">
          <input 
            id="conversion-first-name"
            type="text" 
            placeholder="שם פרטי" 
            class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
          />
          <input 
            id="conversion-last-name"
            type="text" 
            placeholder="שם משפחה" 
            class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
          />
        </div>
        <input 
          id="conversion-phone-number"
          type="tel" 
          placeholder="050-000-0000" 
          class="w-full px-4 py-3 rounded-xl border-2 border-stone-300 dark:border-zinc-700 focus:border-blue-900 dark:focus:border-blue-700 focus:outline-none text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 transition-all"
          dir="ltr"
        />
        <label class="flex items-start gap-3 text-sm text-stone-700 dark:text-stone-300 cursor-pointer p-3 bg-stone-50 dark:bg-zinc-800 rounded-lg border border-stone-200 dark:border-zinc-700">
          <input id="conversion-consent-checkbox" type="checkbox" class="mt-1 w-5 h-5 rounded border-stone-300 text-blue-900 focus:ring-blue-900 focus:ring-2" />
          <span>קראתי ואני מסכים/ה ל<a href="/terms" class="text-blue-600 dark:text-blue-400 hover:underline font-semibold">תקנון ומדיניות הפרטיות</a></span>
        </label>
        <button id="conversion-submit-btn" type="button" class="w-full px-6 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-xl font-semibold transition-all transform hover:scale-105 whitespace-nowrap">
          דברו איתי 🤖
        </button>
      </div>
      
      <div class="flex items-center justify-center gap-6 mt-6">
        <span class="text-sm text-stone-600 dark:text-stone-400">
          תגובה מיידית ⚡
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: scale(0.85) translateY(15px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>

<script>
  // Conversion form validation - isolated script
  (function() {
    const form = document.getElementById('conversion-form-container');
    const submitBtn = document.getElementById('conversion-submit-btn');
    const firstName = document.getElementById('conversion-first-name');
    const lastName = document.getElementById('conversion-last-name');
    const phone = document.getElementById('conversion-phone-number');
    const checkbox = document.getElementById('conversion-consent-checkbox');
    
    if (!form || !submitBtn) return;
    
    // Helper function to set error state
    function setError(input, isError) {
      if (isError) {
        input.classList.remove('border-stone-300', 'dark:border-zinc-700');
        input.classList.add('border-red-500');
      } else {
        input.classList.remove('border-red-500');
        input.classList.add('border-stone-300', 'dark:border-zinc-700');
      }
    }
    
    // Remove error when typing
    firstName.addEventListener('input', () => setError(firstName, false));
    lastName.addEventListener('input', () => setError(lastName, false));
    phone.addEventListener('input', () => setError(phone, false));
    
    checkbox.addEventListener('change', () => {
      if (checkbox.checked) {
        checkbox.classList.remove('ring-2', 'ring-red-500');
        checkbox.parentElement.classList.remove('text-red-600', 'border-red-500');
      }
    });
    
    submitBtn.addEventListener('click', () => {
      let isValid = true;
      
      // Clear all errors first
      setError(firstName, false);
      setError(lastName, false);
      setError(phone, false);
      checkbox.classList.remove('ring-2', 'ring-red-500');
      checkbox.parentElement.classList.remove('text-red-600', 'border-red-500');
      
      // Validate each field
      if (!firstName.value.trim()) {
        setError(firstName, true);
        isValid = false;
      }
      
      if (!lastName.value.trim()) {
        setError(lastName, true);
        isValid = false;
      }
      
      if (!phone.value.trim()) {
        setError(phone, true);
        isValid = false;
      } else {
        const phoneDigits = phone.value.replace(/\D/g, '');
        if (phoneDigits.length < 9) {
          setError(phone, true);
          isValid = false;
        }
      }
      
      if (!checkbox.checked) {
        checkbox.classList.add('ring-2', 'ring-red-500');
        checkbox.parentElement.classList.add('text-red-600', 'border-red-500');
        isValid = false;
      }
      
      if (!isValid) return;
      
      // Success!
      form.classList.add('bg-green-50', 'border-green-500');
      submitBtn.textContent = 'הפרטים התקבלו! ✓';
      submitBtn.classList.remove('bg-blue-900');
      submitBtn.classList.add('bg-green-600');
      
      // Demo API
      fetch('https://jsonplaceholder.typicode.com/posts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          form: 'conversion',
          firstName: firstName.value,
          lastName: lastName.value,
          phone: phone.value
        })
      }).then(res => res.json())
        .then(data => console.log('✅ Conversion form sent:', data))
        .catch(err => console.log('❌ Error:', err));
      
      // Clear fields immediately - form stays green forever, button stays green forever
      firstName.value = '';
      lastName.value = '';
      phone.value = '';
      checkbox.checked = false;
    });
  })();
</script>