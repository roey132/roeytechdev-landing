<!-- CONCEPT 5: SOCIAL PROOF HEAVY SOLUTIONS -->
<section id="services" class="py-24 bg-white dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-green-600 dark:text-green-400 font-semibold mb-4">השירותים שלנו</p>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-4">
        פתרונות ש-150+ עסקים כבר בחרו
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300">
        כל שירות עם תוצאות מוכחות מלקוחות אמיתיים
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Service 1 -->
      <div class="bg-stone-50 dark:bg-zinc-900 rounded-3xl p-8 border border-stone-100 dark:border-zinc-800 hover:border-green-200 dark:hover:border-green-700 transition-all">
        <div class="text-center mb-6">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">💬</span>
          </div>
          <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">צ'אטבוט וואטסאפ</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 text-center mb-6">עונה על כל פנייה 24/7. מסנן לידים, מעביר אליך רק מה שחשוב.</p>
        
        <div class="bg-white dark:bg-zinc-950 rounded-xl p-4 mb-4">
          <p class="text-sm text-stone-500 dark:text-stone-400 text-center mb-2">תוצאות ממוצעות:</p>
          <div class="flex justify-around">
            <div class="text-center">
              <div class="text-xl font-bold text-green-600 dark:text-green-400">87%</div>
              <div class="text-xs text-stone-400">פחות זמן תגובה</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-green-600 dark:text-green-400">3x</div>
              <div class="text-xs text-stone-400">יותר לידים</div>
            </div>
          </div>
        </div>
        
        <p class="text-sm text-stone-500 dark:text-stone-400 text-center italic">"עלה מ-15 ל-45 לידים ביום" — דני, נדל"ן</p>
      </div>

      <!-- Service 2 -->
      <div class="bg-stone-50 dark:bg-zinc-900 rounded-3xl p-8 border border-stone-100 dark:border-zinc-800 hover:border-green-200 dark:hover:border-green-700 transition-all">
        <div class="text-center mb-6">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">🌐</span>
          </div>
          <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">צ'אטבוט לאתר</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 text-center mb-6">לוכד לידים גם כשאתה לא שם. מופיע ברגע הנכון, משאיר לך ליד מוכן.</p>
        
        <div class="bg-white dark:bg-zinc-950 rounded-xl p-4 mb-4">
          <p class="text-sm text-stone-500 dark:text-stone-400 text-center mb-2">תוצאות ממוצעות:</p>
          <div class="flex justify-around">
            <div class="text-center">
              <div class="text-xl font-bold text-green-600 dark:text-green-400">40%</div>
              <div class="text-xs text-stone-400">יותר המרות</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-green-600 dark:text-green-400">24/7</div>
              <div class="text-xs text-stone-400">זמינות</div>
            </div>
          </div>
        </div>
        
        <p class="text-sm text-stone-500 dark:text-stone-400 text-center italic">"המכירות עלו ב-40% בחודש הראשון" — משה, איקומרס</p>
      </div>

      <!-- Service 3 -->
      <div class="bg-gradient-to-br from-green-50 to-white dark:from-green-900/20 dark:to-zinc-900 rounded-3xl p-8 border-2 border-green-200 dark:border-green-700">
        <div class="text-center mb-6">
          <div class="w-16 h-16 bg-green-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">✨</span>
          </div>
          <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">חבילה מלאה</h3>
        </div>
        <p class="text-stone-600 dark:text-stone-300 text-center mb-6">התקנה, חיבור ל-CRM, הדרכה לצוות, תמיכה. הכל כלול.</p>
        
        <div class="bg-white dark:bg-zinc-950 rounded-xl p-4 mb-4">
          <p class="text-sm text-stone-500 dark:text-stone-400 text-center mb-2">מה כלול:</p>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-300">
            <div class="flex items-center gap-2">
              <span class="text-green-500">✓</span>
              <span>התקנה והגדרה מלאה</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-500">✓</span>
              <span>חיבור למערכות קיימות</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-500">✓</span>
              <span>הדרכה לצוות</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-green-500">✓</span>
              <span>תמיכה ושדרוגים</span>
            </div>
          </div>
        </div>
        
        <p class="text-sm text-stone-500 dark:text-stone-400 text-center italic">"היינו מוכנים לעבודה תוך שבוע" — רחל, תיירות</p>
      </div>
    </div>
  </div>
</section>
