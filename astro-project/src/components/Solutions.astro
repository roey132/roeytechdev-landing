---
---

<!-- CONCEPT 1: RESULTS-FIRST SOLUTIONS -->
<section id="services" class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">מה תקבל</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        תוצאות, לא הבטחות
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        כל שירות מגיע עם מדדים ברורים ותוצאות מדידות
      </p>
    </div>
    
    <div class="space-y-6">
      <!-- Service 1 - Chatbot -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-green-300 dark:hover:border-green-700 transition-all hover:shadow-lg">
        <div class="grid md:grid-cols-4 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">צ'אטבוט וואטסאפ</h3>
                <p class="text-sm text-green-600 dark:text-green-400 font-medium">עובד 24/7, לא נחלש לעולם</p>
              </div>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              כל לקוח שפונה מקבל תשובה מיידית. שאלות נפוצות מטופלות אוטומטית. רק לידים רלוונטיים מגיעים אליך.
            </p>
          </div>
          
          <!-- Outcome metrics -->
          <div class="md:col-span-2">
            <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-2xl p-6 border border-green-200 dark:border-green-800">
              <p class="text-sm text-stone-500 dark:text-stone-400 mb-4 font-medium">תוצאות ממוצעות:</p>
              <div class="grid grid-cols-3 gap-4">
                <div class="text-center">
                  <div class="text-3xl font-black text-green-600 dark:text-green-400">87%</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">פחות זמן תגובה</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-black text-green-600 dark:text-green-400">3x</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">יותר לידים</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-black text-green-600 dark:text-green-400">80%</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">אוטומציה</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Service 2 - Website Chatbot -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-green-300 dark:hover:border-green-700 transition-all hover:shadow-lg">
        <div class="grid md:grid-cols-4 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">צ'אטבוט לאתר</h3>
                <p class="text-sm text-green-600 dark:text-green-400 font-medium">לוכד לידים גם כשאתה ישן</p>
              </div>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              מבקרים באתר לא צריכים לחכות. הצ'אטבוט מופיע ברגע הנכון, לוכד פרטים, ומעביר אליך ליד מוכן.
            </p>
          </div>
          
          <!-- Outcome metrics -->
          <div class="md:col-span-2">
            <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-2xl p-6 border border-green-200 dark:border-green-800">
              <p class="text-sm text-stone-500 dark:text-stone-400 mb-4 font-medium">תוצאות ממוצעות:</p>
              <div class="grid grid-cols-3 gap-4">
                <div class="text-center">
                  <div class="text-3xl font-black text-green-600 dark:text-green-400">40%</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">יותר המרות</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-black text-green-600 dark:text-green-400">24/7</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">זמינות</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-black text-green-600 dark:text-green-400">2x</div>
                  <div class="text-xs text-stone-500 dark:text-stone-400">ROI</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Service 3 - Full System -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-green-300 dark:hover:border-green-700 transition-all hover:shadow-lg">
        <div class="grid md:grid-cols-4 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">מערכת מלאה</h3>
                <p class="text-sm text-green-600 dark:text-green-400 font-medium">הכל כלול - התקנה, הדרכה, תמיכה</p>
              </div>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              מתקינים, מגדירים, מחברים ל-CRM וליומן. מכשירים את הצוות. תמיכה ושדרוגים כלולים. אתה רק נהנה מהתוצאות.
            </p>
          </div>
          
          <!-- Outcome metrics -->
          <div class="md:col-span-2">
            <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-2xl p-6 border border-green-200 dark:border-green-800">
              <p class="text-sm text-stone-500 dark:text-stone-400 mb-4 font-medium">מה כלול:</p>
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <span class="text-green-500">✓</span>
                  <span class="text-stone-700 dark:text-stone-300">התקנה והגדרה מלאה</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-green-500">✓</span>
                  <span class="text-stone-700 dark:text-stone-300">חיבור למערכות קיימות</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-green-500">✓</span>
                  <span class="text-stone-700 dark:text-stone-300">הדרכה לצוות</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-green-500">✓</span>
                  <span class="text-stone-700 dark:text-stone-300">תמיכה ושדרוגים שוטפים</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom CTA -->
    <div class="mt-12 text-center">
      <a href="#roi-calculator" class="inline-flex items-center gap-2 px-8 py-4 bg-stone-900 dark:bg-stone-100 hover:bg-green-600 dark:hover:bg-green-600 text-white dark:text-zinc-900 hover:text-white rounded-full font-bold text-lg transition-all">
        חשב את החיסכון שלך
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
