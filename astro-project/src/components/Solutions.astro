---
---

<section id="services" class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider">השירותים שלנו</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        פתרונות אוטומציה שבאמת עובדות
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        מערכות מותאמות אישית שמעוצבות לצרכים הספציפיים של העסק שלך
      </p>
    </div>
    
    <div class="space-y-6">
      <!-- Service 1 -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">
                פיתוח צ'אטבוט חכם
              </h3>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              צ'אטבוט AI מתקדם לוואטסאפ, אינסטגרם ופייסבוק שלוכד לידים, עונה לשאלות נפוצות ומסנן לקוחות באופן אוטומטי - 24/7
            </p>
          </div>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-400">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>ליכוד לידים מיידי</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>סינון אוטומטי</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>העברה חלקה לבני אדם</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Service 2 -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">
                ארכיטקטורת CRM מותאמת
              </h3>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              מערכות CRM קלות משקל ועוצמתיות שנבנות עם כלים כמו Airtable שמארגנות את נתוני הלקוחות ומאוטמטות מעקב
            </p>
          </div>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-400">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>נתוני לקוחות מרוכזים</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>מעקב אוטומטי</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>ממשק קל לשימוש</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Service 3 -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">
                אוטומציה של תהליכי עבודה
              </h3>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              חיבור הכלים הקיימים שלך מאחורי הקלעים באמצעות פלטפורמות כמו n8n או Make כדי לחסל משימות חוזרות לתמיד
            </p>
          </div>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-400">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>אוטומציית אימייל</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>אינטגרציה לרשתות חברתיות</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>עיצוב תהליכי עבודה מותאמים</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
