---
---

<section id="services" class="py-24 bg-white dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        איך זה עובד?
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl mx-auto">
        תהליך פשוט ומהיר שמוביל למערכת אוטומטית שמנהלת את הלידים שלכם
      </p>
    </div>
    
    <div class="space-y-16">
      <!-- Step 1 - AI/Automated Chatbot -->
      <div class="grid md:grid-cols-2 gap-12 items-center scroll-reveal">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 to-blue-600/20 rounded-3xl transform rotate-3"></div>
          <div class="relative bg-gradient-to-br from-blue-500 to-blue-600 rounded-3xl p-12 text-white transform -rotate-1 hover:rotate-0 transition-transform">
            <div class="flex items-center justify-center h-64">
              <div class="text-center">
                <div class="w-24 h-24 bg-white/20 rounded-3xl flex items-center justify-center mx-auto mb-6 backdrop-blur-sm">
                  <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <p class="text-xl font-bold">AI</p>
                <p class="text-blue-100">אוטומטי</p>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-6">
          <h3 class="text-3xl font-bold text-stone-900 dark:text-stone-100">
            צ'אטבוט AI אוטומטי
          </h3>
          <p class="text-lg text-stone-600 dark:text-stone-300 leading-relaxed">
            צאטבוט AI חכם שמותאם לעסק וללקוחות שלכם ומנהל את השיחות עם הלקוחות בצורה אוטונומית. הוא עונה על שאלות נפוצות, מספק מידע, ומסנן לידים חמים - כל זה בלי שתצטרכו להרים טלפון.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">עלייה לאוויר תוך ימים בודדים!</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">מותאם אישית לעסק שלכם</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">מענה ללקוחות 24/7 ללא הפסקה</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Step 2 - Organized Leads with Data -->
      <div class="grid md:grid-cols-2 gap-12 items-center scroll-reveal delay-100">
        <div class="space-y-6 order-2 md:order-1">
          <h3 class="text-3xl font-bold text-stone-900 dark:text-stone-100">
            לידים מאורגנים עם נתונים
          </h3>
          <p class="text-lg text-stone-600 dark:text-stone-300 leading-relaxed">
            כל שיחה עם לקוח נשמרת במערכת עם כל הפרטים: שם, טלפון, אימייל, והעניין שלהם. הנתונים מאורגנים בצורה מסודרת בCRM.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">איסוף אוטומטי של פרטי הלקוח</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">סינון לידים לפי איכות ועניין</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">סינכרון עם מערכות קיימות</span>
            </div>
          </div>
        </div>
        <div class="relative order-1 md:order-2">
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/20 to-indigo-600/20 rounded-3xl transform -rotate-3"></div>
          <div class="relative bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-3xl p-12 text-white transform rotate-1 hover:rotate-0 transition-transform">
            <div class="flex items-center justify-center h-64">
              <div class="text-center">
                <div class="w-24 h-24 bg-white/20 rounded-3xl flex items-center justify-center mx-auto mb-6 backdrop-blur-sm">
                  <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </div>
                <p class="text-xl font-bold">לידים</p>
                <p class="text-indigo-100">מאורגנים</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Step 3 - Everything in One System -->
      <div class="grid md:grid-cols-2 gap-12 items-center scroll-reveal delay-200">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/20 to-purple-600/20 rounded-3xl transform rotate-3"></div>
          <div class="relative bg-gradient-to-br from-purple-500 to-purple-600 rounded-3xl p-12 text-white transform -rotate-1 hover:rotate-0 transition-transform">
            <div class="flex items-center justify-center h-64">
              <div class="text-center">
                <div class="w-24 h-24 bg-white/20 rounded-3xl flex items-center justify-center mx-auto mb-6 backdrop-blur-sm">
                  <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
                  </svg>
                </div>
                <p class="text-xl font-bold">הכל</p>
                <p class="text-purple-100">במערכת אחת</p>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-6">
          <h3 class="text-3xl font-bold text-stone-900 dark:text-stone-100">
            הכל במערכת אחת - אוטומציות והודעות
          </h3>
          <p class="text-lg text-stone-600 dark:text-stone-300 leading-relaxed">
            כל האוטומציות, ההודעות וניהול הלידים במקום אחד. המערכת כוללת CRM פנימי, ניהול שיחות, מנהלת אוטומציות ועובדת באופן אוטומטי ללא התערבות ידנית.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">אוטומציות מותאמות אישית</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">הודעות ותזכורות אוטומטיות</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-base font-semibold text-stone-700 dark:text-stone-300">סינכרון למערכות שלכם</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- CTA Section -->
    <div class="mt-20 text-center scroll-reveal">
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-full font-bold transition-all transform hover:scale-105 shadow-xl">
        קבעו פגישת ייעוץ חינמית
      </a>
    </div>
  </div>
</section>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: scale(0.85) translateY(15px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>