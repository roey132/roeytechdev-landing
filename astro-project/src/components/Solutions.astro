---
---

<section id="services" class="py-20 bg-slate-50 dark:bg-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Automation Solutions That Actually Work
      </h2>
      <p class="text-xl text-slate-600 dark:text-slate-300">
        Custom-built systems designed for your specific business needs
      </p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white dark:bg-slate-900 p-8 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700">
        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">
          Smart Chatbot Development
        </h3>
        <p class="text-slate-600 dark:text-slate-300 mb-4">
          24/7 AI-powered chatbots for WhatsApp, Instagram, and Facebook that capture leads, answer FAQs, and qualify customers automatically.
        </p>
        <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Instant lead capture</li>
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Automated qualification</li>
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Seamless handoff to humans</li>
        </ul>
      </div>
      
      <div class="bg-white dark:bg-slate-900 p-8 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700">
        <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">
          Custom CRM Architecture
        </h3>
        <p class="text-slate-600 dark:text-slate-300 mb-4">
          Lightweight, powerful CRM systems built with tools like Airtable that organize your customer data and automate follow-ups.
        </p>
        <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Centralized customer data</li>
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Automated follow-ups</li>
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Easy to use interface</li>
        </ul>
      </div>
      
      <div class="bg-white dark:bg-slate-900 p-8 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700">
        <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3">
          Workflow Automation
        </h3>
        <p class="text-slate-600 dark:text-slate-300 mb-4">
          Connect your existing tools behind the scenes using platforms like n8n or Make to eliminate repetitive tasks forever.
        </p>
        <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Email automation</li>
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Social media integration</li>
          <li class="flex items-center"><span class="text-green-500 mr-2">✓</span> Custom workflow design</li>
        </ul>
      </div>
    </div>
  </div>
</section>
