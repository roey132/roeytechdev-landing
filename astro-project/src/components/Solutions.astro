<!-- CONCEPT 3: MINIMALIST SOLUTIONS -->
<section id="solutions" class="py-32 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-24">
      <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-6">הפתרון</p>
      <h2 class="text-4xl md:text-5xl font-light text-stone-900 dark:text-stone-100">
        מה תקבל
      </h2>
    </div>
    
    <div class="space-y-16">
      
      <!-- Solution 1 -->
      <div class="text-center max-w-2xl mx-auto">
        <h3 class="text-2xl font-light text-stone-900 dark:text-stone-100 mb-4">
          צ'אטבוט וואטסאפ
        </h3>
        <p class="text-lg font-light text-stone-500 dark:text-stone-400">
          עונה על כל פנייה, 24/7. מסנן לידים, מעביר אליך רק מה שחשוב.
        </p>
      </div>
      
      <!-- Solution 2 -->
      <div class="text-center max-w-2xl mx-auto">
        <h3 class="text-2xl font-light text-stone-900 dark:text-stone-100 mb-4">
          צ'אטבוט לאתר
        </h3>
        <p class="text-lg font-light text-stone-500 dark:text-stone-400">
          לוכד לידים גם כשאתה לא שם. מופיע ברגע הנכון, משאיר לך ליד מוכן.
        </p>
      </div>
      
      <!-- Solution 3 -->
      <div class="text-center max-w-2xl mx-auto">
        <h3 class="text-2xl font-light text-stone-900 dark:text-stone-100 mb-4">
          הכל כלול
        </h3>
        <p class="text-lg font-light text-stone-500 dark:text-stone-400">
          התקנה, הגדרה, חיבור למערכות, הדרכה, תמיכה. אתה רק נהנה.
        </p>
      </div>
    </div>
  </div>
</section>
