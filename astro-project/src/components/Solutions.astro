---
---

<section id="services" class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider">Our Services</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        Automation Solutions That Actually Work
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        Custom-built systems designed for your specific business needs
      </p>
    </div>
    
    <div class="space-y-6">
      <!-- Service 1 -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">
                Smart Chatbot Development
              </h3>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              24/7 AI-powered chatbots for WhatsApp, Instagram, and Facebook that capture leads, answer FAQs, and qualify customers automatically.
            </p>
          </div>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-400">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Instant lead capture</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Automated qualification</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Seamless handoff to humans</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Service 2 -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">
                Custom CRM Architecture
              </h3>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              Lightweight, powerful CRM systems built with tools like Airtable that organize your customer data and automate follow-ups.
            </p>
          </div>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-400">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Centralized customer data</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Automated follow-ups</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Easy to use interface</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Service 3 -->
      <div class="group relative bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">
                Workflow Automation
              </h3>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              Connect your existing tools behind the scenes using platforms like n8n or Make to eliminate repetitive tasks forever.
            </p>
          </div>
          <div class="space-y-2 text-sm text-stone-600 dark:text-stone-400">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Email automation</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Social media integration</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-stone-400 dark:bg-zinc-600 rounded-full"></span>
              <span>Custom workflow design</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
