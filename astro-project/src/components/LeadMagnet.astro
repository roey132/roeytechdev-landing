<!-- CONCEPT 3: MINIMALIST LEAD MAGNET -->
<section class="py-32 bg-white dark:bg-zinc-950">
  <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-6">מדריך חינמי</p>
    
    <h2 class="text-3xl md:text-4xl font-light text-stone-900 dark:text-stone-100 mb-8">
      איך לדעת אם אוטומציה מתאימה לך
    </h2>
    
    <p class="font-light text-stone-500 dark:text-stone-400 mb-12">
      10 שאלות. תשובות ברורות. בלי ספאם.
    </p>
    
    <form class="space-y-4">
      <input 
        type="email" 
        placeholder="אימייל"
        class="w-full px-6 py-4 rounded-full bg-stone-50 dark:bg-zinc-900 border border-stone-200 dark:border-zinc-800 text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-1 focus:ring-green-500 text-center font-light"
      />
      <button 
        type="submit"
        class="w-full bg-stone-900 dark:bg-stone-100 hover:bg-green-600 dark:hover:bg-green-600 text-white dark:text-zinc-900 px-6 py-4 rounded-full font-light text-lg transition-all"
      >
        קבל את המדריך
      </button>
    </form>
  </div>
</section>
