---
---

<!-- CONCEPT 1: RESULTS-FIRST LEAD MAGNET -->
<section class="py-24 bg-gradient-to-br from-stone-900 via-stone-800 to-stone-900 dark:from-zinc-950 dark:via-zinc-900 dark:to-zinc-950 text-white relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-0 left-0 w-96 h-96 bg-green-600 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-green-500 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="bg-white dark:bg-zinc-900 rounded-3xl overflow-hidden shadow-2xl">
      <div class="grid md:grid-cols-2">
        <!-- Left side - Offer -->
        <div class="p-10 md:p-12 bg-gradient-to-br from-green-600 to-green-700 text-white">
          <div class="inline-flex items-center gap-2 bg-white/20 px-3 py-1 rounded-full text-sm font-medium mb-6">
            <span class="text-yellow-300">⭐</span>
            מדריך חינמי
          </div>
          
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">
            חשב את ה-ROI של אוטומציה לעסק שלך
          </h2>
          
          <p class="text-lg text-green-100 mb-8 leading-relaxed">
            מדריך צעד-אחר-צעד לחישוב כמה זמן וכסף אתה יכול לחסוך עם צ'אטבוט AI. כולל נוסחאות, טבלאות, ודוגמאות אמיתיות.
          </p>
          
          <!-- What's inside -->
          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <span class="text-white">✓</span>
              </div>
              <span class="text-green-100">נוסחת חישוב ROI מותאמת</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <span class="text-white">✓</span>
              </div>
              <span class="text-green-100">טבלת חיסכון לפי גודל עסק</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <span class="text-white">✓</span>
              </div>
              <span class="text-green-100">5 דוגמאות מעסקים אמיתיים</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <span class="text-white">✓</span>
              </div>
              <span class="text-green-100">תבנית אקסל מוכנה לשימוש</span>
            </div>
          </div>
          
          <!-- Stats -->
          <div class="bg-white/10 rounded-xl p-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold">2,500+</div>
                <div class="text-xs text-green-200">הורדות</div>
              </div>
              <div>
                <div class="text-2xl font-bold">4.8/5</div>
                <div class="text-xs text-green-200">דירוג</div>
              </div>
              <div>
                <div class="text-2xl font-bold">12 עמודים</div>
                <div class="text-xs text-green-200">תוכן</div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Right side - Form -->
        <div class="p-10 md:p-12 bg-stone-50 dark:bg-zinc-950 flex flex-col justify-center">
          <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-2">
            קבל את המדריך עכשיו
          </h3>
          <p class="text-stone-600 dark:text-stone-400 mb-8">
            ללא עלות, ללא ספאם. רק תוכן שיעזור לך לקבל החלטה מושכלת.
          </p>
          
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-2">שם מלא</label>
              <input 
                type="text" 
                placeholder="השם שלך"
                class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-stone-200 dark:border-zinc-700 text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-green-500 transition-all"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-2">אימייל</label>
              <input 
                type="email" 
                placeholder="your@email.com"
                class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-stone-200 dark:border-zinc-700 text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-green-500 transition-all"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-2">סוג העסק (אופציונלי)</label>
              <select class="w-full px-4 py-3 rounded-xl bg-white dark:bg-zinc-900 border border-stone-200 dark:border-zinc-700 text-stone-900 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-green-500 transition-all">
                <option value="">בחר...</option>
                <option value="realestate">נדל"ן</option>
                <option value="ecommerce">איקומרס</option>
                <option value="services">שירותים מקצועיים</option>
                <option value="hospitality">תיירות ואירוח</option>
                <option value="other">אחר</option>
              </select>
            </div>
            
            <button 
              type="submit"
              class="w-full bg-green-600 hover:bg-green-700 text-white px-6 py-4 rounded-xl font-bold text-lg transition-all transform hover:scale-[1.02] flex items-center justify-center gap-2"
            >
              קבל את המדריך החינמי
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
          </form>
          
          <p class="text-xs text-stone-400 dark:text-stone-500 mt-4 text-center">
            🔒 הפרטים שלך מאובטחים. לא נשלח ספאם אי-פעם.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Testimonial -->
    <div class="mt-8 text-center">
      <p class="text-stone-400 dark:text-stone-500 text-sm italic">
        "המדריך הזה עזר לי להבין בדיוק כמה אני מפסיד כל יום בלי אוטומציה. החלטתי ליישם תוך שבוע."
      </p>
      <p class="text-stone-500 dark:text-stone-600 text-xs mt-2">— יוסי ל., בעלים של חברת הובלות</p>
    </div>
  </div>
</section>
