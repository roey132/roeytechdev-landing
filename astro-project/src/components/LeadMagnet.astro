<!-- CONCEPT 4: STORY-DRIVEN LEAD MAGNET -->
<section class="py-24 bg-gradient-to-br from-stone-900 to-stone-800 dark:from-zinc-950 dark:to-zinc-900 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="bg-white dark:bg-zinc-900 rounded-3xl p-10 md:p-14 text-stone-900 dark:text-stone-100">
      <p class="text-green-600 dark:text-green-400 font-semibold mb-4">מדריך חינמי</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">איך נראה הסוף הטוב שלך?</h2>
      <p class="text-lg text-stone-600 dark:text-stone-300 mb-8 max-w-xl mx-auto">
        מדריך שמספר את הסיפור של בעלי עסקים שכתבו סוף אחר לסיפור שלהם — ואיך אתה יכול לעשות את זה גם.
      </p>

      <div class="grid md:grid-cols-2 gap-4 mb-8 text-right">
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">5 סיפורים אמיתיים של שינוי</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">הפרקים של כל סיפור מוצלח</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">איך לזהות שאתה מוכן לשינוי</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">הצעד הראשון לסוף טוב</span>
        </div>
      </div>

      <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
        <input 
          type="email" 
          placeholder="האימייל שלך"
          class="flex-1 px-6 py-4 rounded-xl bg-stone-50 dark:bg-zinc-800 border border-stone-200 dark:border-zinc-700 text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-green-500"
        />
        <button class="bg-green-600 hover:bg-green-700 text-white px-8 py-4 rounded-xl font-bold transition-all">
          קבל את המדריך
        </button>
      </form>
    </div>
  </div>
</section>
