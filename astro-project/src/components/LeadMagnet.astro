<!-- CONCEPT 5: SOCIAL PROOF HEAVY LEAD MAGNET -->
<section class="py-24 bg-white dark:bg-zinc-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-green-600 dark:text-green-400 font-semibold mb-4">מדריך חינמי</p>
    <h2 class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100 mb-4">
      150 עסקים. 150 שיעורים.
    </h2>
    <p class="text-lg text-stone-600 dark:text-stone-300 mb-8 max-w-xl mx-auto">
      ליקטנו את התובנות הכי חשובות מ-150 לקוחות למדריך אחד שיחסוך לך טעויות.
    </p>

    <div class="bg-stone-50 dark:bg-zinc-900 rounded-3xl p-8 border border-stone-200 dark:border-zinc-800">
      <div class="grid md:grid-cols-2 gap-4 mb-8 text-right">
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">10 טעויות נפוצות ואיך להימנע מהן</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">ROI ממוצע לפי תעשייה</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">זמן החזר ROI מצופה</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-green-500 mt-1">✓</span>
          <span class="text-stone-600 dark:text-stone-300">5 סודות מ-150 לקוחות</span>
        </div>
      </div>

      <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
        <input 
          type="email" 
          placeholder="האימייל שלך"
          class="flex-1 px-6 py-4 rounded-xl bg-white dark:bg-zinc-800 border border-stone-200 dark:border-zinc-700 text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-green-500"
        />
        <button class="bg-green-600 hover:bg-green-700 text-white px-8 py-4 rounded-xl font-bold transition-all">
          קבל עכשיו
        </button>
      </form>

      <p class="text-stone-400 dark:text-stone-500 text-sm mt-4">
        📧 נשלח ל-2,500+ בעלי עסקים • דירוג 4.8/5
      </p>
    </div>
  </div>
</section>
