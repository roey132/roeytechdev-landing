<script>
  // Handle phone form submissions
  document.addEventListener('DOMContentLoaded', () => {
    const phoneInputs = document.querySelectorAll('input[type="tel"]');
    const submitButtons = document.querySelectorAll('button');
    
    submitButtons.forEach((button, index) => {
      if (button.textContent.includes('דברו') || button.textContent.includes('קבעו')) {
        button.addEventListener('click', (e) => {
          e.preventDefault();
          
          // Get the corresponding phone input
          const form = button.closest('div').parentElement;
          const phoneInput = form.querySelector('input[type="tel"]');
          
          if (phoneInput && phoneInput.value) {
            const phoneNumber = phoneInput.value;
            
            // For now, open WhatsApp with the phone number
            const message = `היי, השארתי את המספר: ${phoneNumber}. אשמח לשמוע עוד על אוטומציה לעסק שלי.`;
            const whatsappUrl = `https://wa.me/972500000000?text=${encodeURIComponent(message)}`;
            window.open(whatsappUrl, '_blank');
            
            // Show success message
            button.textContent = 'המספר התקבל! ✓';
            button.classList.remove('bg-green-600', 'hover:bg-green-700');
            button.classList.add('bg-green-800');
            
            setTimeout(() => {
              button.textContent = button.textContent.includes('קבעו') ? 'קבעו ייעוץ חינמי 📱' : 'דברו איתי 📱';
              button.classList.add('bg-green-600', 'hover:bg-green-700');
              button.classList.remove('bg-green-800');
              phoneInput.value = '';
            }, 3000);
          } else {
            // Show error - shake animation
            phoneInput.classList.add('border-red-500');
            phoneInput.placeholder = 'נא להזין מספר טלפון';
            setTimeout(() => {
              phoneInput.classList.remove('border-red-500');
              phoneInput.placeholder = '050-000-0000';
            }, 2000);
          }
        });
      }
    });
    
    // Format phone number as user types
    phoneInputs.forEach(input => {
      input.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        
        if (value.length > 0) {
          if (value.length <= 3) {
            value = value;
          } else if (value.length <= 6) {
            value = value.slice(0, 3) + '-' + value.slice(3);
          } else {
            value = value.slice(0, 3) + '-' + value.slice(3, 6) + '-' + value.slice(6, 10);
          }
        }
        
        e.target.value = value;
      });
    });
  });
</script>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
    20%, 40%, 60%, 80% { transform: translateX(5px); }
  }
  
  .border-red-500 {
    animation: shake 0.5s;
  }
</style>