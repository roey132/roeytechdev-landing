---
---

<!-- Accessibility Button -->
<div id="accessibility-container" class="fixed bottom-6 left-6 z-50">
  <button 
    id="accessibility-toggle" 
    aria-label="הגדרות נגישות"
    class="flex items-center justify-center w-14 h-14 bg-blue-900 hover:bg-blue-800 text-white rounded-full shadow-lg transition-all transform hover:scale-110"
    title="הגדרות נגישות"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
    </svg>
  </button>

  <!-- Accessibility Panel -->
  <div 
    id="accessibility-panel" 
    class="hidden absolute bottom-16 left-0 w-80 bg-white dark:bg-zinc-900 rounded-2xl shadow-2xl border-2 border-blue-900/20 dark:border-blue-800/30 overflow-hidden"
    role="dialog"
    aria-labelledby="accessibility-title"
  >
    <div class="p-6">
      <h3 id="accessibility-title" class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-6">
        הגדרות נגישות
      </h3>

      <div class="space-y-4">
        <!-- Text Size -->
        <div class="space-y-2">
          <label class="text-sm font-semibold text-stone-700 dark:text-stone-300 block">
            גודל טקסט
          </label>
          <div class="flex gap-2">
            <button 
              id="a11y-text-decrease"
              class="flex-1 px-4 py-2 bg-stone-100 dark:bg-zinc-800 hover:bg-stone-200 dark:hover:bg-zinc-700 text-stone-900 dark:text-stone-100 rounded-lg font-semibold transition-all"
              aria-label="הקטן טקסט"
            >
              A-
            </button>
            <button 
              id="a11y-text-reset"
              class="flex-1 px-4 py-2 bg-stone-100 dark:bg-zinc-800 hover:bg-stone-200 dark:hover:bg-zinc-700 text-stone-900 dark:text-stone-100 rounded-lg font-semibold transition-all"
              aria-label="איפוס גודל טקסט"
            >
              איפוס
            </button>
            <button 
              id="a11y-text-increase"
              class="flex-1 px-4 py-2 bg-stone-100 dark:bg-zinc-800 hover:bg-stone-200 dark:hover:bg-zinc-700 text-stone-900 dark:text-stone-100 rounded-lg font-semibold transition-all"
              aria-label="הגדל טקסט"
            >
              A+
            </button>
          </div>
        </div>

        <!-- High Contrast -->
        <div class="space-y-2">
          <label class="text-sm font-semibold text-stone-700 dark:text-stone-300 block">
            ניגודיות גבוהה
          </label>
          <button 
            id="a11y-contrast-toggle"
            class="w-full px-4 py-2 bg-stone-100 dark:bg-zinc-800 hover:bg-stone-200 dark:hover:bg-zinc-700 text-stone-900 dark:text-stone-100 rounded-lg font-semibold transition-all"
            aria-label="הפעל/כבה ניגודיות גבוהה"
          >
            הפעל ניגודיות גבוהה
          </button>
        </div>

        <!-- Dark/Light Mode -->
        <div class="space-y-2">
          <label class="text-sm font-semibold text-stone-700 dark:text-stone-300 block">
            מצב צבעים
          </label>
          <div class="flex gap-2">
            <button 
              id="a11y-light-mode"
              class="flex-1 px-4 py-2 bg-stone-100 hover:bg-stone-200 text-stone-900 rounded-lg font-semibold transition-all"
              aria-label="מצב בהיר"
            >
              ☀️ בהיר
            </button>
            <button 
              id="a11y-dark-mode"
              class="flex-1 px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-white rounded-lg font-semibold transition-all"
              aria-label="מצב כהה"
            >
              🌙 כהה
            </button>
          </div>
        </div>

        <!-- Underline Links -->
        <div class="space-y-2">
          <label class="text-sm font-semibold text-stone-700 dark:text-stone-300 block">
            הדגשת קישורים
          </label>
          <button 
            id="a11y-links-toggle"
            class="w-full px-4 py-2 bg-stone-100 dark:bg-zinc-800 hover:bg-stone-200 dark:hover:bg-zinc-700 text-stone-900 dark:text-stone-100 rounded-lg font-semibold transition-all"
            aria-label="הפעל/כבה הדגשת קישורים"
          >
            הדגש קישורים
          </button>
        </div>

        <!-- Reset All -->
        <div class="pt-4 border-t border-stone-200 dark:border-zinc-700">
          <button 
            id="a11y-reset-all"
            class="w-full px-4 py-3 bg-blue-900 hover:bg-blue-800 text-white rounded-lg font-semibold transition-all"
            aria-label="איפוס כל הגדרות נגישות"
          >
            איפוס כל ההגדרות
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* High contrast mode styles */
  .a11y-high-contrast {
    --tw-bg-opacity: 1 !important;
  }
  
  .a11y-high-contrast * {
    background-color: white !important;
    color: black !important;
  }
  
  .a11y-high-contrast a {
    color: blue !important;
    text-decoration: underline !important;
    font-weight: bold !important;
  }
  
  .a11y-high-contrast button {
    background-color: black !important;
    color: white !important;
    border: 2px solid white !important;
  }
  
  /* Underline links */
  .a11y-underline-links a {
    text-decoration: underline !important;
    text-decoration-thickness: 2px !important;
    text-underline-offset: 2px !important;
  }
  
  /* Text size adjustments */
  .a11y-text-sm {
    font-size: 87.5% !important;
  }
  
  .a11y-text-base {
    font-size: 100% !important;
  }
  
  .a11y-text-lg {
    font-size: 112.5% !important;
  }
  
  .a11y-text-xl {
    font-size: 125% !important;
  }
  
  .a11y-text-2xl {
    font-size: 137.5% !important;
  }
  
  .a11y-text-3xl {
    font-size: 150% !important;
  }

  /* Focus styles for keyboard navigation */
  #accessibility-toggle:focus,
  #accessibility-panel button:focus {
    outline: 3px solid #1e3a8a;
    outline-offset: 2px;
  }
</style>

<script>
  (function() {
    const toggle = document.getElementById('accessibility-toggle');
    const panel = document.getElementById('accessibility-panel');
    const body = document.body;
    
    if (!toggle || !panel) return;
    
    // Toggle panel
    toggle.addEventListener('click', () => {
      panel.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', !panel.classList.contains('hidden'));
    });
    
    // Close panel when clicking outside
    document.addEventListener('click', (e) => {
      if (!panel.contains(e.target) && !toggle.contains(e.target)) {
        panel.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
    
    // Text size controls
    const textDecrease = document.getElementById('a11y-text-decrease');
    const textReset = document.getElementById('a11y-text-reset');
    const textIncrease = document.getElementById('a11y-text-increase');
    
    let currentTextSize = parseInt(localStorage.getItem('a11y-text-size') || '0');
    
    function updateTextSize() {
      body.classList.remove('a11y-text-sm', 'a11y-text-base', 'a11y-text-lg', 'a11y-text-xl', 'a11y-text-2xl', 'a11y-text-3xl');
      
      switch(currentTextSize) {
        case -2: body.classList.add('a11y-text-sm'); break;
        case -1: body.classList.add('a11y-text-lg'); break;
        case 0: /* default */ break;
        case 1: body.classList.add('a11y-text-xl'); break;
        case 2: body.classList.add('a11y-text-2xl'); break;
        case 3: body.classList.add('a11y-text-3xl'); break;
      }
      
      localStorage.setItem('a11y-text-size', currentTextSize.toString());
    }
    
    textDecrease.addEventListener('click', () => {
      if (currentTextSize > -2) {
        currentTextSize--;
        updateTextSize();
      }
    });
    
    textReset.addEventListener('click', () => {
      currentTextSize = 0;
      updateTextSize();
    });
    
    textIncrease.addEventListener('click', () => {
      if (currentTextSize < 3) {
        currentTextSize++;
        updateTextSize();
      }
    });
    
    // High contrast toggle
    const contrastToggle = document.getElementById('a11y-contrast-toggle');
    let isHighContrast = localStorage.getItem('a11y-high-contrast') === 'true';
    
    if (isHighContrast) {
      body.classList.add('a11y-high-contrast');
      contrastToggle.textContent = 'כבה ניגודיות גבוהה';
    }
    
    contrastToggle.addEventListener('click', () => {
      isHighContrast = !isHighContrast;
      body.classList.toggle('a11y-high-contrast');
      localStorage.setItem('a11y-high-contrast', isHighContrast.toString());
      contrastToggle.textContent = isHighContrast ? 'כבה ניגודיות גבוהה' : 'הפעל ניגודיות גבוהה';
    });
    
    // Light/Dark mode
    const lightMode = document.getElementById('a11y-light-mode');
    const darkMode = document.getElementById('a11y-dark-mode');
    
    lightMode.addEventListener('click', () => {
      if (typeof window.toggleTheme === 'function') {
        window.toggleTheme();
      }
    });
    
    darkMode.addEventListener('click', () => {
      if (typeof window.toggleTheme === 'function') {
        window.toggleTheme();
      }
    });
    
    // Underline links
    const linksToggle = document.getElementById('a11y-links-toggle');
    let underlineLinks = localStorage.getItem('a11y-underline-links') === 'true';
    
    if (underlineLinks) {
      body.classList.add('a11y-underline-links');
      linksToggle.textContent = 'הסר הדגשת קישורים';
    }
    
    linksToggle.addEventListener('click', () => {
      underlineLinks = !underlineLinks;
      body.classList.toggle('a11y-underline-links');
      localStorage.setItem('a11y-underline-links', underlineLinks.toString());
      linksToggle.textContent = underlineLinks ? 'הסר הדגשת קישורים' : 'הדגש קישורים';
    });
    
    // Reset all
    const resetAll = document.getElementById('a11y-reset-all');
    
    resetAll.addEventListener('click', () => {
      // Reset text size
      currentTextSize = 0;
      updateTextSize();
      
      // Reset high contrast
      isHighContrast = false;
      body.classList.remove('a11y-high-contrast');
      localStorage.setItem('a11y-high-contrast', 'false');
      contrastToggle.textContent = 'הפעל ניגודיות גבוהה';
      
      // Reset underline links
      underlineLinks = false;
      body.classList.remove('a11y-underline-links');
      localStorage.setItem('a11y-underline-links', 'false');
      linksToggle.textContent = 'הדגש קישורים';
      
      // Reset to light mode
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    });
    
    // Initialize text size
    updateTextSize();
  })();
</script>
