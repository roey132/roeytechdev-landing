---
---
<div class="relative w-[320px] mx-auto" id="phone-demo-hero">
  <!-- Modern Minimal Phone -->
  <div class="relative bg-gradient-to-br from-slate-800 to-slate-900 rounded-[3rem] p-2.5 shadow-2xl">
    <!-- Dynamic Island -->
    <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-32 h-7 bg-black rounded-b-2xl z-10"></div>
    
    <!-- Inner Screen -->
    <div class="bg-white dark:bg-zinc-950 rounded-[2.5rem] overflow-hidden flex flex-col h-[640px]">
      <!-- Clean Header -->
      <div class="bg-gradient-to-r from-blue-500 to-blue-600 dark:from-blue-600 dark:to-blue-700 px-4 pt-10 pb-4 flex items-center gap-3 flex-shrink-0">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-white font-bold text-base">רועיטק</div>
          <div class="text-blue-100 text-xs">אוטומציה חכמה</div>
        </div>
      </div>

      <!-- Messages Container -->
      <div class="flex-1 overflow-y-auto overflow-x-hidden px-3 py-4 space-y-2 bg-gradient-to-b from-gray-50 to-white dark:from-zinc-900 dark:to-zinc-950" id="chat-messages-hero">
        <!-- Messages will be inserted here -->
        <!-- Typing Indicator will be inserted here dynamically -->
      </div>

      <!-- Clean Footer -->
      <div class="bg-white dark:bg-zinc-900 border-t border-gray-100 dark:border-zinc-800 px-4 py-3 flex items-center gap-2">
        <div class="flex-1 bg-gray-100 dark:bg-zinc-800 rounded-full px-4 py-2">
          <div id="typing-input-hero" class="text-gray-800 dark:text-gray-200 text-sm min-h-[20px]"></div>
        </div>
        <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 send-button-hero">
          <svg class="w-5 h-5 text-white transform rotate-180" fill="currentColor" viewBox="0 0 24 24">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </div>
      </div>
      
      <!-- Home Indicator -->
      <div class="bg-white dark:bg-zinc-900 flex justify-center items-center py-2">
        <div class="w-32 h-1 bg-gray-300 dark:bg-zinc-600 rounded-full"></div>
      </div>
    </div>
  </div>
</div>

<style>
  #chat-messages-hero {
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
  }

  #chat-messages-hero::-webkit-scrollbar {
    width: 4px;
  }

  #chat-messages-hero::-webkit-scrollbar-track {
    background: transparent;
  }

  #chat-messages-hero::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 2px;
  }

  .message-animation {
    animation: messageSlideIn 0.4s ease-out forwards;
  }

  @keyframes messageSlideIn {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.8);
    }
    60% {
      transform: translateY(-5px) scale(1.02);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  const messages = [
    { type: 'customer', text: 'היי, אני מאבד המון זמן על שאלות חוזרות בווטסאפ ולא מגיע ללידים החדשים.' },
    { type: 'bot', text: 'בדיוק בשביל זה אני כאן. ⚡ אני יכול לענות לכולם תוך שניות, לסנן לידים לא רלוונטיים ולתאם פגישות ביומן שלך.' },
    { type: 'customer', text: 'וזה נשמר לי במערכת בצורה מסודרת?' },
    { type: 'bot', text: 'בטח. כל ליד נשמר בצורה מסודרת ומתועדת בטבלאות או בCRM. רוצה לראות איך הבוט שלך יתחיל לעבוד?' },
    { type: 'typing', text: 'כן, בוא נתקדם!' },
  ];

  let currentMessageIndex = 0;
  const chatMessages = document.getElementById('chat-messages-hero');
  const typingInput = document.getElementById('typing-input-hero');
  const sendButton = document.querySelector('.send-button-hero');
  let typingIndicatorElement = null;

  function createTypingIndicator(type) {
    const indicatorDiv = document.createElement('div');
    const isCustomer = type === 'customer';
    
    indicatorDiv.className = `flex ${isCustomer ? 'justify-start' : 'justify-end'}`;
    
    const bubbleClass = isCustomer
      ? 'bg-white dark:bg-zinc-800 rounded-2xl rounded-br-sm shadow-sm'
      : 'bg-blue-500 rounded-2xl rounded-bl-sm shadow-sm';
    
    const dotColor = isCustomer ? 'bg-blue-400' : 'bg-white';
    
    indicatorDiv.innerHTML = `
      <div class="inline-flex items-center gap-1 ${bubbleClass} px-3 py-1.5">
        <div class="flex gap-0.5">
          <div class="w-1.5 h-1.5 ${dotColor} rounded-full animate-bounce" style="animation-delay: 0ms"></div>
          <div class="w-1.5 h-1.5 ${dotColor} rounded-full animate-bounce" style="animation-delay: 150ms"></div>
          <div class="w-1.5 h-1.5 ${dotColor} rounded-full animate-bounce" style="animation-delay: 300ms"></div>
        </div>
      </div>
    `;
    return indicatorDiv;
  }

  function createMessageElement(message) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `flex ${message.type === 'customer' ? 'justify-start' : 'justify-end'}`;

    const bubbleClass = message.type === 'customer'
      ? 'bg-white dark:bg-zinc-800 text-gray-900 dark:text-stone-100 rounded-2xl rounded-br-sm shadow-sm'
      : 'bg-blue-500 text-white rounded-2xl rounded-bl-sm shadow-sm';

    messageDiv.innerHTML = `
      <div class="max-w-[85%] ${bubbleClass} px-3 py-1.5">
        <p class="text-xs leading-relaxed">${message.text}</p>
        <div class="text-[8px] mt-0.5 ${message.type === 'customer' ? 'text-gray-400 dark:text-zinc-500' : 'text-blue-100'} flex items-center justify-end gap-0.5">
          <span>${new Date().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' })}</span>
        </div>
      </div>
    `;

    return messageDiv;
  }

  function showTyping(type) {
    if (!typingIndicatorElement) {
      typingIndicatorElement = createTypingIndicator(type);
    }
    chatMessages.appendChild(typingIndicatorElement);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function hideTyping() {
    if (typingIndicatorElement && typingIndicatorElement.parentNode) {
      typingIndicatorElement.parentNode.removeChild(typingIndicatorElement);
    }
  }

  function addMessage(message) {
    // Remove typing indicator before adding message
    if (typingIndicatorElement && typingIndicatorElement.parentNode) {
      typingIndicatorElement.parentNode.removeChild(typingIndicatorElement);
    }
    
    const messageElement = createMessageElement(message);
    messageElement.style.opacity = '0';
    messageElement.style.transform = 'scale(0.8) translateY(20px)';
    
    chatMessages.appendChild(messageElement);
    
    void messageElement.offsetHeight;
    
    requestAnimationFrame(() => {
      messageElement.style.transition = 'all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55)';
      messageElement.style.opacity = '1';
      messageElement.style.transform = 'scale(1) translateY(0)';
      
      setTimeout(() => {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }, 100);
    });
  }

  async function typeMessage(text, callback) {
    typingInput.textContent = '';
    for (let i = 0; i < text.length; i++) {
      typingInput.textContent += text[i];
      await new Promise(resolve => setTimeout(resolve, 25 + Math.random() * 25));
    }
    
    // Show send button animation
    sendButton.style.transform = 'scale(1.1)';
    await new Promise(resolve => setTimeout(resolve, 100));
    sendButton.style.transform = 'scale(1)';
    
    // Clear input and callback
    typingInput.textContent = '';
    callback();
  }

  async function playConversation() {
    if (currentMessageIndex >= messages.length) {
      await new Promise(resolve => setTimeout(resolve, 2000));
      chatMessages.innerHTML = '';
      currentMessageIndex = 0;
    }

    const message = messages[currentMessageIndex];

    if (message.type === 'typing') {
      // Show typing indicator for customer
      showTyping('customer');
      await new Promise(resolve => setTimeout(resolve, 1000));
      hideTyping();
      // Then send the message
      await typeMessage(message.text, () => {
        addMessage({ type: 'customer', text: message.text });
        currentMessageIndex++;
        setTimeout(playConversation, 300);
      });
    } else if (message.type === 'customer') {
      // Type message in input
      await typeMessage(message.text, () => {
        addMessage(message);
        currentMessageIndex++;
        setTimeout(playConversation, 300);
      });
    } else {
      // Show typing indicator for bot
      showTyping('bot');
      await new Promise(resolve => setTimeout(resolve, 750));
      hideTyping();
      addMessage(message);
      currentMessageIndex++;
      setTimeout(playConversation, 500);
    }
  }

  setTimeout(playConversation, 1000);
</script>