<style>
  .answer-reveal {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateY(10px);
  }

  .answer-reveal:not(.opacity-100) {
    opacity: 0;
    pointer-events: none;
  }

  .answer-reveal.opacity-100 {
    opacity: 1;
    transform: translateY(0);
  }

  .message-faq-item {
    transition: all 0.3s ease;
  }

  .message-faq-item:hover {
    transform: translateY(-2px);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.message-faq-item');
    
    faqItems.forEach(item => {
      const question = item.querySelector('.cursor-pointer');
      const answer = item.querySelector('.answer-reveal');
      
      question.addEventListener('click', () => {
        const isOpen = answer.classList.contains('opacity-100');
        
        // Close all others in same container
        const container = item.closest('.space-y-3, .space-y-4');
        container.querySelectorAll('.answer-reveal').forEach(otherAnswer => {
          if (otherAnswer !== answer) {
            otherAnswer.classList.remove('opacity-100');
            otherAnswer.style.opacity = '0';
          }
        });
        
        // Toggle current
        if (isOpen) {
          answer.classList.remove('opacity-100');
          answer.style.opacity = '0';
        } else {
          answer.classList.add('opacity-100');
          answer.style.opacity = '1';
        }
      });
    });
  });
</script>
