---
import PhoneDemo1 from './PhoneDemo1.astro';
import PhoneDemo2 from './PhoneDemo2.astro';
import PhoneDemo3 from './PhoneDemo3.astro';
---

<section class="bg-gradient-to-br from-slate-100 via-blue-50 to-purple-50 dark:from-slate-900 dark:via-zinc-900 dark:to-indigo-950 py-16 border-b border-slate-200 dark:border-zinc-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-stone-100 mb-3">Phone Demo Variations</h2>
      <p class="text-slate-600 dark:text-slate-400">Three different styles - same message animation</p>
    </div>

    <div class="flex flex-wrap justify-center gap-8 items-start">
      <!-- Phone 1: Modern Minimal -->
      <div class="flex flex-col items-center">
        <PhoneDemo1 />
        <div class="mt-4 text-center">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-stone-100">Modern Minimal</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">Clean blue design</p>
        </div>
      </div>

      <!-- Phone 2: Dark WhatsApp Style -->
      <div class="flex flex-col items-center">
        <PhoneDemo2 />
        <div class="mt-4 text-center">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-stone-100">Dark WhatsApp</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">Classic messaging look</p>
        </div>
      </div>

      <!-- Phone 3: Premium Gradient -->
      <div class="flex flex-col items-center">
        <PhoneDemo3 />
        <div class="mt-4 text-center">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-stone-100">Premium Gradient</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">Luxury glass morphism</p>
        </div>
      </div>
    </div>
  </div>
</section>