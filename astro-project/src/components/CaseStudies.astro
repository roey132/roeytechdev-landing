---
---

<section id="case-studies" class="py-24 bg-stone-50 dark:bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-stone-500 dark:text-stone-400 uppercase tracking-wider">Case Studies</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        Real Results for Real Businesses
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        See how automation has transformed businesses like yours
      </p>
    </div>
    
    <div class="space-y-8">
      <!-- Case Study 1 -->
      <div class="group bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-5 gap-8">
          <div class="md:col-span-3 space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-stone-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-2xl font-bold text-stone-700 dark:text-stone-300">
                VR
              </div>
              <div>
                <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">Villa Rentals Company</h3>
                <p class="text-sm text-stone-500 dark:text-stone-400">Hospitality • 50+ Properties</p>
              </div>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              "Our WhatsApp bot now handles 90% of guest inquiries automatically. Booking inquiries increased by 40% and we saved 25 hours per week."
            </p>
          </div>
          <div class="md:col-span-2 grid grid-cols-2 gap-6">
            <div class="text-center p-4 bg-stone-50 dark:bg-zinc-950 rounded-2xl">
              <div class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-1">25+</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">Hours/Week</div>
            </div>
            <div class="text-center p-4 bg-stone-50 dark:bg-zinc-950 rounded-2xl">
              <div class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-1">40%</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">More Inquiries</div>
            </div>
            <div class="text-center p-4 bg-stone-50 dark:bg-zinc-950 rounded-2xl col-span-2">
              <div class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-1">90%</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">Automated Responses</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Case Study 2 -->
      <div class="group bg-white dark:bg-zinc-900 rounded-3xl p-8 md:p-10 border border-stone-200 dark:border-zinc-800 hover:border-stone-300 dark:hover:border-zinc-700 transition-all">
        <div class="grid md:grid-cols-5 gap-8">
          <div class="md:col-span-3 space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-stone-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-2xl font-bold text-stone-700 dark:text-stone-300">
                EC
              </div>
              <div>
                <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">E-commerce Brand</h3>
                <p class="text-sm text-stone-500 dark:text-stone-400">Retail • Instagram Ads</p>
              </div>
            </div>
            <p class="text-stone-600 dark:text-stone-300 text-lg leading-relaxed">
              "The Instagram automation bot increased our ad conversion rate by 35%. Customer questions are answered instantly, even at 3 AM."
            </p>
          </div>
          <div class="md:col-span-2 grid grid-cols-2 gap-6">
            <div class="text-center p-4 bg-stone-50 dark:bg-zinc-950 rounded-2xl">
              <div class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-1">35%</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">Higher Conversion</div>
            </div>
            <div class="text-center p-4 bg-stone-50 dark:bg-zinc-950 rounded-2xl">
              <div class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-1">24/7</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">Support</div>
            </div>
            <div class="text-center p-4 bg-stone-50 dark:bg-zinc-950 rounded-2xl col-span-2">
              <div class="text-3xl font-bold text-stone-900 dark:text-stone-100 mb-1">3x</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">ROI in 2 Months</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
