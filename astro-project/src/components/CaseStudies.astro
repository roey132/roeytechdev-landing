<!-- CONCEPT 5: SOCIAL PROOF HEAVY CASE STUDIES -->
<section id="case-studies" class="py-24 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-green-600 dark:text-green-400 font-semibold mb-4">מקרי בוחן</p>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100">
        תוצאות אמיתיות לעסקים אמיתיים
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 mt-4">
        ראו איך אוטומציה שינתה עסקים כמו שלכם
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Case 1 -->
      <div class="bg-white dark:bg-zinc-950 rounded-3xl p-8 shadow-lg border border-stone-100 dark:border-zinc-800">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 bg-stone-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-2xl font-bold text-stone-600 dark:text-stone-300">VR</div>
          <div>
            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">חברת השכרת וילות</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400">אירוח • 50+ נכסים</p>
          </div>
        </div>
        <p class="text-stone-600 dark:text-stone-300 mb-6">"הבוט שלנו בוואטסאפ מטפל עכשיו ב-90% מהפניות באופן אוטומטי. פניות הזמנות עלו ב-40% וחסכנו 25 שעות בשבוע."</p>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center p-3 bg-stone-50 dark:bg-zinc-900 rounded-xl">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400">25+</div>
            <div class="text-xs text-stone-500">שעות/שבוע</div>
          </div>
          <div class="text-center p-3 bg-stone-50 dark:bg-zinc-900 rounded-xl">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400">40%</div>
            <div class="text-xs text-stone-500">עלייה בפניות</div>
          </div>
          <div class="text-center p-3 bg-stone-50 dark:bg-zinc-900 rounded-xl">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400">90%</div>
            <div class="text-xs text-stone-500">מענה אוטומטי</div>
          </div>
        </div>
      </div>

      <!-- Case 2 -->
      <div class="bg-white dark:bg-zinc-950 rounded-3xl p-8 shadow-lg border border-stone-100 dark:border-zinc-800">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 bg-stone-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-2xl font-bold text-stone-600 dark:text-stone-300">EC</div>
          <div>
            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">מותג איקומרס</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400">קמעונאות • מודעות אינסטגרם</p>
          </div>
        </div>
        <p class="text-stone-600 dark:text-stone-300 mb-6">"הבוט לאוטומציה באינסטגרם הגדיל את שיעור ההמרה של המודעות שלנו ב-35%. שאלות לקוחות נענות מיידית, אפילו ב-3 בבוקר."</p>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center p-3 bg-stone-50 dark:bg-zinc-900 rounded-xl">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400">35%</div>
            <div class="text-xs text-stone-500">שיעור המרה</div>
          </div>
          <div class="text-center p-3 bg-stone-50 dark:bg-zinc-900 rounded-xl">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400">24/7</div>
            <div class="text-xs text-stone-500">תמיכה</div>
          </div>
          <div class="text-center p-3 bg-stone-50 dark:bg-zinc-900 rounded-xl">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400">3x</div>
            <div class="text-xs text-stone-500">החזר השקעה</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
