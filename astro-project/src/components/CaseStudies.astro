---

<section class="py-20 bg-stone-100 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">מקרי בוחן</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-6 leading-tight">
        תוצאות אמיתיות לעסקים אמיתיים
      </h2>
      <p class="text-xl text-stone-600 dark:text-stone-300 max-w-2xl">
        ראו איך עסקים כמו שלכם כבר צמחו עם הפתרונות שלנו
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Case Study 1 -->
      <div class="group bg-white dark:bg-zinc-950 rounded-3xl p-8 border border-stone-200 dark:border-zinc-800 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-xl transition-all scroll-reveal">
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div>
              <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">וילת בוטיק בצפון</h3>
              <p class="text-sm text-stone-500 dark:text-stone-400">הצעת מחירים אוטומטית</p>
            </div>
          </div>
          
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
            בוט אוטומטי לווצאפ שאוסף מידע מלקוחות לגבי זמני האירוח, כמות אנשים ועוד מידע רלוונטי, עד הצעת מחיר אוטומטית מותאמת על פי חגים וימים מיוחדים. ללא התערבות אדם!
          </p>
          
          <div class="grid grid-cols-3 gap-4">
            <div class="text-center p-3 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
              <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">25+</div>
              <div class="text-xs text-stone-500 dark:text-stone-400">שעות/שבוע</div>
            </div>
            <div class="text-center p-3 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
              <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">40%</div>
              <div class="text-xs text-stone-500 dark:text-stone-400">עלייה בפניות</div>
            </div>
            <div class="text-center p-3 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
              <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">90%</div>
              <div class="text-xs text-stone-500 dark:text-stone-400">מענה אוטומטי</div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Case Study 2 -->
      <div class="group bg-white dark:bg-zinc-950 rounded-3xl p-8 border border-stone-200 dark:border-zinc-800 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-xl transition-all scroll-reveal delay-100">
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div>
              <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100">חנות איקומרס</h3>
              <p class="text-sm text-stone-500 dark:text-stone-400">בוט שירות לקוחות</p>
            </div>
          </div>
          
          <p class="text-stone-600 dark:text-stone-300 leading-relaxed">
בוט כפתורים משולב AI שיודע לענות ללקוחות על שאלות על המוצרים, להתחבר למערכות פנימיות ולעדכן לקוחות לגבי סטטוס ההזמנה שלהם, חוסך זמן ומשפר את חווית הלקוח ללא המתנה לנציג.
          
          <div class="grid grid-cols-3 gap-4">
            <div class="text-center p-3 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
              <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">35%</div>
              <div class="text-xs text-stone-500 dark:text-stone-400">שיפור המרה</div>
            </div>
            <div class="text-center p-3 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
              <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">24/7</div>
              <div class="text-xs text-stone-500 dark:text-stone-400">תמיכה</div>
            </div>
            <div class="text-center p-3 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
              <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">3x</div>
              <div class="text-xs text-stone-500 dark:text-stone-400">החזר השקעה</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- CTA Section -->
    <div class="mt-12 text-center scroll-reveal">
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-blue-900 hover:bg-blue-800 text-white rounded-full font-bold transition-all transform hover:scale-105 shadow-xl">
        התחילו עוד היום
      </a>
    </div>
  </div>
</section>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: scale(0.85) translateY(15px);
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>
