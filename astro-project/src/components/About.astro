<!-- CONCEPT 4: STORY-DRIVEN ABOUT -->
<section class="py-24 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-6">
        <div class="inline-block">
          <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">הסיפור שלי</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 leading-tight">
          כל סיפור התחיל איפשהו
        </h2>
        
        <div class="space-y-4 text-lg text-stone-600 dark:text-stone-300 leading-relaxed">
          <p>
            היי, אני רועי. הסיפור שלי התחיל כשראיתי בעלי עסקים טובים שנשחקים — אנשים שהתחילו את העסק שלהם מתוך תשוקה, ומצאו את עצמם תקועים במענה לשאלות חוזרות במקום לעשות את מה שהם אוהבים.
          </p>
          <p>
            החלטתי שמישהו צריך לעזור להם לכתוב סוף אחר לסיפור הזה. לא למכור להם פתרונות קסם — אלא להקשיב, להבין, ולבנות משהו שבאמת עובד.
          </p>
          <p>
            היום אני עוזר לעסקים לכתוב פרק חדש בסיפור שלהם — פרק של שקט נפשי, זמן פנוי, ועסק שעובד בשבילם, לא ההפך.
          </p>
        </div>
      </div>
      
      <div class="relative">
        <div class="bg-white dark:bg-zinc-950 rounded-3xl shadow-xl border border-stone-100 dark:border-zinc-800 p-8">
          <div class="text-center mb-8">
            <div class="w-24 h-24 bg-gradient-to-br from-green-400 to-green-600 rounded-full mx-auto mb-4 flex items-center justify-center">
              <span class="text-4xl font-bold text-white">ר</span>
            </div>
            <h3 class="text-2xl font-bold text-stone-900 dark:text-stone-100">רועי טק-דב</h3>
            <p class="text-stone-500 dark:text-stone-400">כותב סיפורים עם סוף טוב</p>
          </div>
          
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">50+</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">סיפורים נכתבו</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">98%</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">סופות טובות</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">3+</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">שנות כתיבה</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
