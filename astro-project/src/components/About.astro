    </p>
    
    <div class="grid grid-cols-3 gap-8">
      <div>
        <div class="text-3xl font-extralight text-green-600 dark:text-green-400">50+</div>
        <div class="text-sm font-light text-stone-400 dark:text-stone-500 mt-2">פרויקטים</div>
      </div>
      <div>
        <div class="text-3xl font-extralight text-green-600 dark:text-green-400">3+</div>
        <div class="text-sm font-light text-stone-400 dark:text-stone-500 mt-2">שנים</div>
      </div>
      <div>
        <div class="text-3xl font-extralight text-green-600 dark:text-green-400">98%</div>
        <div class="text-sm font-light text-stone-400 dark:text-stone-500 mt-2">שביעות רצון</div>
      </div>
    </div>
  </div>
</section>
