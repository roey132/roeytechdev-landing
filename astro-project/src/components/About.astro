<!-- CONCEPT 3: MINIMALIST ABOUT -->
<section class="py-32 bg-stone-50 dark:bg-zinc-900">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-sm font-light text-stone-400 dark:text-stone-500 tracking-widest uppercase mb-6">קצת עלי</p>
    
    <div class="mb-8">
      <div class="w-20 h-20 bg-gradient-to-br from-stone-200 to-stone-300 dark:from-zinc-700 dark:to-zinc-600 rounded-full mx-auto flex items-center justify-center">
        <span class="text-3xl font-extralight text-stone-600 dark:text-stone-200">ר</span>
      </div>
    </div>
    
    <h2 class="text-3xl font-light text-stone-900 dark:text-stone-100 mb-6">
      רועי טק-דב
