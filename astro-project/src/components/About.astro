---
---

<section class="py-24 bg-stone-100 dark:bg-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left - Image/Visual -->
      <div class="relative">
        <div class="relative bg-white dark:bg-zinc-950 rounded-3xl shadow-2xl p-8 border border-stone-200 dark:border-zinc-800">
          <!-- Profile Image Placeholder -->
          <div class="aspect-square bg-gradient-to-br from-green-100 to-green-200 dark:from-green-900/30 dark:to-green-800/30 rounded-2xl flex items-center justify-center">
            <div class="text-center">
              <div class="w-24 h-24 bg-green-600 dark:bg-green-500 rounded-full mx-auto mb-4 flex items-center justify-center">
                <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
              </div>
              <div class="text-2xl font-bold text-stone-900 dark:text-stone-100">רועי טק-דב</div>
              <div class="text-stone-600 dark:text-stone-400 mt-1">מפתח אוטומציה AI</div>
            </div>
          </div>
          
          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4 mt-6">
            <div class="text-center">
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">50+</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">פרויקטים</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">3+</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">שנות ניסיון</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">100%</div>
              <div class="text-sm text-stone-500 dark:text-stone-400">שביעות</div>
            </div>
          </div>
        </div>
        
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -left-4 w-full h-full bg-green-100 dark:bg-green-900/30 rounded-3xl -z-10"></div>
      </div>
      
      <!-- Right - Content -->
      <div class="space-y-6">
        <div class="inline-block">
          <span class="text-sm font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider">קצת עלי</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-bold text-stone-900 dark:text-stone-100 leading-tight">
          מי העומד מאחורי הצ'אטבוטים?
        </h2>
        
        <div class="space-y-4 text-lg text-stone-600 dark:text-stone-300 leading-relaxed">
          <p>
            היי, אני רועי טק-דב, מפתח AI ואוטומציה עם תשוקה לעסקים. אני מאמין שכל עסק צריך אוטומציה - השאלה רק איך ולאן.
          </p>
          
          <p>
            הגעתי לעולם האוטומציה אחרי שעבדתי עם עשרות עסקים שנאבקו באותן בעיות: לידים שנעלמים, זמן תגובה איטי, ומשימות חוזרות ששואבות שעות יקרות.
          </p>
          
          <p>
            היום אני עוזר לעסקים ליישם צ'אטבוט AI חכמים שלוכדים לידים 24/7, מערכות CRM אוטומטיות ומערכות עבודה שחוסכות שעות יקרות של עבודה ידנית.
          </p>
        </div>
        
        <!-- Skills/Expertise -->
        <div class="bg-white dark:bg-zinc-950 rounded-2xl p-6 border border-stone-200 dark:border-zinc-800">
          <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 mb-4">התמחויות שלי</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-600 rounded-full"></div>
              <span class="text-stone-700 dark:text-stone-300">צ'אטבוטי AI</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-600 rounded-full"></div>
              <span class="text-stone-700 dark:text-stone-300">CRM אוטומטי</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-600 rounded-full"></div>
              <span class="text-stone-700 dark:text-stone-300">n8n & Make</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-600 rounded-full"></div>
              <span class="text-stone-700 dark:text-stone-300">אינטגרציות API</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-600 rounded-full"></div>
              <span class="text-stone-700 dark:text-stone-300">WhatsApp Business</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-600 rounded-full"></div>
              <span class="text-stone-700 dark:text-stone-300">אוטומציה עסקית</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
