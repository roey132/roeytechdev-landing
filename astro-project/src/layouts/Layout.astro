---
interface Props {
  title?: string;
}

const { title = "RoeyTechDev - Automation Solutions" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AI chatbots, custom CRMs, and workflow automation for modern businesses" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles.css" />
    <script is:inline>
      // Dark mode logic - runs immediately to prevent flash
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 transition-colors">
    <slot />
    
    <script is:inline>
      // Theme toggle functionality
      function toggleTheme() {
        const html = document.documentElement;
        const current = html.classList.contains('dark') ? 'dark' : 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        
        if (next === 'light') {
          html.classList.remove('dark');
        } else {
          html.classList.add('dark');
        }
        
        localStorage.setItem('theme', next);
      }
      
      // Make toggle function available globally for the button
      window.toggleTheme = toggleTheme;
    </script>
  </body>
</html>
