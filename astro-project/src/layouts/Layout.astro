---
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
}

const { title = "רועיטק - Automation Solutions" } = Astro.props;
---

<!DOCTYPE html>
<html lang="he" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AI chatbots, custom CRMs, and workflow automation for modern businesses" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles.css" />
    <script is:inline>
      // Dark mode logic - runs immediately to prevent flash
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="bg-stone-50 dark:bg-zinc-950 text-stone-900 dark:text-stone-100 transition-colors font-sans antialiased">
    <slot />
    <CookieConsent />
    
    <script is:inline>
      // Phone form functionality
      document.addEventListener('DOMContentLoaded', () => {
        const phoneInputs = document.querySelectorAll('input[type="tel"]');
        
        // Format phone number as user types
        phoneInputs.forEach(input => {
          input.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            
            if (value.length > 0) {
              if (value.length <= 3) {
                value = value;
              } else if (value.length <= 6) {
                value = value.slice(0, 3) + '-' + value.slice(3);
              } else {
                value = value.slice(0, 3) + '-' + value.slice(3, 6) + '-' + value.slice(6, 10);
              }
            }
            
            e.target.value = value;
          });
        });
        
        // Handle form submissions
        document.querySelectorAll('button').forEach(button => {
          const buttonText = button.textContent.trim();
          if (buttonText.includes('דברו') || buttonText.includes('קבעו')) {
            button.addEventListener('click', (e) => {
              e.preventDefault();
              
              const formContainer = button.closest('div').parentElement;
              const phoneInput = formContainer?.querySelector('input[type="tel"]');
              
              if (phoneInput && phoneInput.value) {
                const phoneNumber = phoneInput.value;
                const message = `היי, השארתי את המספר: ${phoneNumber}. אשמח לשמוע עוד על אוטומציה לעסק שלי.`;
                const whatsappUrl = `https://wa.me/972557294597?text=${encodeURIComponent(message)}`;
                window.open(whatsappUrl, '_blank');
                
                // Show success feedback
                const originalText = button.innerHTML;
                button.innerHTML = 'המספר התקבל! ✓';
                button.classList.add('bg-blue-800');
                
                setTimeout(() => {
                  button.innerHTML = originalText;
                  button.classList.remove('bg-blue-800');
                  phoneInput.value = '';
                }, 3000);
              } else if (phoneInput) {
                // Show error feedback
                phoneInput.classList.add('border-red-500', 'animate-shake');
                phoneInput.placeholder = 'נא להזין מספר טלפון';
                
                setTimeout(() => {
                  phoneInput.classList.remove('border-red-500', 'animate-shake');
                  phoneInput.placeholder = '055-729-4597';
                }, 2000);
              }
            });
          }
        });
      });
    </script>
    
    <script is:inline>
      // Theme toggle functionality
      function toggleTheme() {
        const html = document.documentElement;
        const current = html.classList.contains('dark') ? 'dark' : 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        
        if (next === 'light') {
          html.classList.remove('dark');
        } else {
          html.classList.add('dark');
        }
        
        localStorage.setItem('theme', next);
      }
      
      // Make toggle function available globally for the button
      window.toggleTheme = toggleTheme;
    </script>
  </body>
</html>
