---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const seoData = {
  title: "תקנון ומדיניות פרטיות | רועיטק - פתרונות אוטומציה",
  description: "תקנון שימוש ומדיניות פרטיות מלאה של רועיטק. כללי שימוש בשירותי אוטומציה ו-AI, הגנת פרטיות מידע לקוחות, זכויות וחובות משפטיות."
};
---

<Layout 
  title={seoData.title}
  description={seoData.description}
>
  <Navbar />
  <main class="min-h-screen py-20 bg-stone-50 dark:bg-zinc-950" role="main">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white dark:bg-zinc-900 rounded-3xl shadow-xl p-8 md:p-12">
        <header class="mb-8 text-center">
          <h1 id="terms-heading" class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-stone-100 mb-4">
            תקנון ותנאי שימוש ומדיניות פרטיות - RoeyTech
          </h1>
          <p class="text-stone-600 dark:text-stone-400">עדכון אחרון: אפריל 2026</p>
        </header>
        
        <div class="prose prose-lg dark:prose-invert max-w-none">
          <p class="text-lg text-stone-600 dark:text-stone-400 mb-8 leading-relaxed">
            ברוכים הבאים לאתר ולשירותיו של רועי אהרונוב (להלן: "העסק"). השימוש באתר, השארת פרטים בטפסים השונים וכן ההתקשרות עם העסק לקבלת שירותים, כפופים לתנאים המפורטים במסמך זה. הגלישה באתר או השארת פרטים מהווה הסכמה מלאה לתנאים אלו.
          </p>

          <section class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-4 pb-2 border-b-2 border-blue-900 dark:border-blue-700">1. הגדרות וכללי</h2>
            <ul class="list-disc pr-6 space-y-3 text-stone-700 dark:text-stone-300">
              <li>התקנון חל על כל משתמש באתר, על מי שמשאיר את פרטיו באמצעי ההתקשרות השונים (טפסי לידים, וואטסאפ, אימייל) ועל כל לקוח של העסק.</li>
              <li>האמור בתקנון זה מתייחס באופן שווה לבני כל המינים, והשימוש בלשון זכר הוא מטעמי נוחות בלבד.</li>
            </ul>
          </section>

          <section class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-4 pb-2 border-b-2 border-blue-900 dark:border-blue-700">2. אופי השירותים והגבלת אחריות</h2>
            <ul class="list-disc pr-6 space-y-3 text-stone-700 dark:text-stone-300">
              <li>העסק מספק שירותי פיתוח, ייעוץ והטמעה בתחומי האוטומציה העסקית, מערכות CRM (כגון Airtable) ובינה מלאכותית (AI).</li>
              <li><strong>שימוש בתשתיות צד ג':</strong> פתרונות העסק מתבססים על שירותים חיצוניים (כגון Make, OpenAI, Google Cloud). המשתמש מצהיר כי ידוע לו ששינויים טכנולוגיים, תקלות או שינויי תמחור מצד ספקים אלו אינם בשליטת העסק, ולא תהיה לו כל טענה כלפי העסק בגין שיבושים הנובעים מכך.</li>
              <li><strong>דיוק תוצרי בינה מלאכותית:</strong> מערכות מבוססות AI עלולות לספק מידע שאינו מדויק או שגוי. האחריות על בדיקת התוצרים ואישורם לשימוש עסקי חלה על הלקוח בלבד.</li>
              <li><strong>הגבלת אחריות:</strong> העסק לא יהיה אחראי לכל נזק ישיר או עקיף, אובדן נתונים או אובדן רווחים הנובע משימוש במערכות שהוטמעו, מעבר למאמץ הסביר לתיקון תקלות במסגרת הסכם השירות.</li>
            </ul>
          </section>

          <section class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-4 pb-2 border-b-2 border-blue-900 dark:border-blue-700">3. מדיניות פרטיות (Privacy Policy)</h2>
            <ul class="list-disc pr-6 space-y-3 text-stone-700 dark:text-stone-300">
              <li><strong>איסוף מידע:</strong> בעת השארת פרטים באתר, המשתמש מוסר מרצונו מידע אישי הכולל שם, טלפון, וכתובת דואר אלקטרוני.</li>
              <li><strong>מטרת איסוף המידע:</strong> המידע משמש ליצירת קשר, מתן השירות המבוקש, התאמת תוכן ושליחת עדכונים מקצועיים או הצעות שיווקיות. המשתמש רשאי לבקש את הסרתו מרשימת התפוצה בכל עת.</li>
              <li><strong>אבטחת מידע:</strong> המידע נשמר במערכות מאובטחות (כגון Airtable) בהתאם לסטנדרטים המקובלים. עם זאת, בסביבה דיגיטלית לא ניתן להבטיח חסינות מוחלטת מפני גישה בלתי מורשית.</li>
              <li><strong>העברת מידע לצד ג':</strong> העסק מתחייב שלא למכור או לסחור בפרטי המשתמש עם צדדים שלישיים לצרכי פרסום.</li>
            </ul>
          </section>

          <section class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-4 pb-2 border-b-2 border-blue-900 dark:border-blue-700">4. קניין רוחני</h2>
            <p class="text-stone-700 dark:text-stone-300">
              כל זכויות היוצרים בידע המקצועי, שיטות העבודה והקודים הגנריים שפותחו על ידי העסק שייכות לו באופן בלעדי. ללקוח ניתנת זכות שימוש בתוצרי העבודה עבורם שילם, לצרכיו העסקיים בלבד.
            </p>
          </section>

          <section class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-4 pb-2 border-b-2 border-blue-900 dark:border-blue-700">5. סמכות שיפוט</h2>
            <p class="text-stone-700 dark:text-stone-300">
              על תקנון זה יחולו חוקי מדינת ישראל. מקום השיפוט הבלעדי בכל עניין הנובע מהסכם זה יהיה בבית המשפט המוסמך במחוז תל אביב.
            </p>
          </section>

          <section class="mt-12 p-6 bg-blue-50 dark:bg-blue-900/20 rounded-2xl border-2 border-blue-200 dark:border-blue-800">
            <p class="text-lg font-semibold text-stone-900 dark:text-stone-100 text-center">
              רועי אהרונוב - עוסק פטור
            </p>
          </section>

          <section class="mt-8 text-center">
            <p class="text-stone-600 dark:text-stone-400 mb-4">
              לשאלות ובירורים נוספים, צרו קשר:
            </p>
            <a href="mailto:roeytechdev@gmail.com" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold text-lg">
              📧 roeytechdev@gmail.com
            </a>
          </section>
        </div>
      </div>
    </div>
  </main>
</Layout>
